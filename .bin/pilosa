# Fetch release notes from GitHub API
fetch_release_notes() {
  local version="${1:-latest}"
  local api_url
  
  if [[ "$version" == "latest" ]]; then
    api_url="https://api.github.com/repos/${PILOSA_REPO}/releases/latest"
  else
    api_url="https://api.github.com/repos/${PILOSA_REPO}/releases/tags/v${version}"
  fi
  
  # Use Python for reliable JSON parsing
  curl -fsSL "$api_url" 2>/dev/null | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    tag = data.get('tag_name', '')
    published = data.get('published_at', '').replace('T', ' ').replace('Z', '')
    body = data.get('body', '')
    print(f'{tag}|{published}|{body}')
except:
    pass
" 2>/dev/null
}

# Display release notes in a formatted way
display_release_notes() {
  local release_data="$1"
  local tag_name published_at body
  
  tag_name="$(echo "$release_data" | cut -d'|' -f1)"
  published_at="$(echo "$release_data" | cut -d'|' -f2)"
  body="$(echo "$release_data" | cut -d'|' -f3-)"

  # Extract key lines: strip markdown, code fences, commands, keep only descriptions
  local lines
  lines="$(echo "$body" | sed -E '
    /^```/d
    /^curl /d
    /^bash /d
    /^pilosa /d
    /^For options/d
    /^Pilosa Framework/d
    /^##+ (Install|Update)/d
    s/^This installs.*/↳ Zero dependencies, bundled OCR/
    s/^- Framework-owned.*/↳ Framework files updated from release/
    s/^- User workspace.*/↳ Your workspace is preserved/
    s/^- Locally modified.*/↳ Modified files get .pilosa-new sidecars/
  ' | sed '/^$/d')"

  printf '\n'
  if [[ -n "$lines" ]]; then
    printf '  %s┌%s┐\n' "${DIM}" "$(printf '%.0s─' 1 {1..60})"
    printf '  %s│%s %s%s%s\n' "${DIM}" "${RESET}" "${BOLD}${tag_name}${RESET}" "${DIM}" "${RESET}"
    printf '  %s├%s┤\n' "${DIM}" "$(printf '%.0s─' 1 {1..60})"
    echo "$lines" | while IFS= read -r line; do
      printf '  %s│%s %s\n' "${DIM}" "${RESET}" "$line"
    done
    printf '  %s└%s┘\n' "${DIM}" "$(printf '%.0s─' 1 {1..60})"
  else
    note "${BOLD}${tag_name}${RESET}"
  fi
  echo ""
}

