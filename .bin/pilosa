# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: onboard
# ═══════════════════════════════════════════════════════════════════════════
cmd_onboard() {
  local workspace_path=""
  local source_dir=""
  local onboard_args
  onboard_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-color) R="" G="" B="" Y="" C="" M="" DIM="" BOLD="" RESET=""; shift ;;
      --gum)     USE_GUM="1"; shift ;;
      --no-gum)  USE_GUM="0"; shift ;;
      --source-dir) source_dir="$2"; shift 2 ;;
      --help|-h)
        echo "Usage: pilosa onboard [workspace-directory] [options]" >&2
        echo "  --source-dir PATH  Pre-select source folder (skip prompt)" >&2
        echo "  --no-color         Disable colored output" >&2
        echo "  --gum              Use interactive Gum prompts" >&2
        echo "  --no-gum           Use plain shell prompts" >&2
        echo "Example:" >&2
        echo "  pilosa onboard --source-dir /Users/me/Documents/archive" >&2
        return 0
        ;;
      -*) die "Unknown option: $1. Valid: --source-dir, --no-color, --gum, --no-gum, --help" ;; 
      *) onboard_args+=("$1"); shift ;;
    esac
  done

  # Use first positional arg as workspace path if provided
  if [[ ${#onboard_args[@]} -gt 0 ]]; then
    workspace_path="${onboard_args[0]}"
  fi

  # Resolve workspace path
  if [[ -n "$workspace_path" ]]; then
    workspace_path="$(require_workspace "$workspace_path")" || return $?
  else
    workspace_path="$(require_workspace)" || return $?
  fi
  cd "$workspace_path" || die "Cannot change to workspace: $workspace_path"

  # Extract existing project name from workspace metadata, or prompt
  local project_name
  project_name="$(grep 'project_name:' "$workspace_path/.pilosa/workspace" 2>/dev/null | sed 's/project_name: *//' | head -1 || echo "")"
  if [[ -z "$project_name" ]]; then
    local default_name
    default_name="$(basename "$workspace_path")"
    while [[ -z "$project_name" ]] || [[ ! "$project_name" =~ ^[a-zA-Z0-9_ -]+$ ]]; do
      project_name="$(prompt_input "Project name" "$default_name")"
      if [[ ! "$project_name" =~ ^[a-zA-Z0-9_ -]+$ ]]; then
        warn "Project name can only contain letters, numbers, spaces, hyphens, and underscores."
        project_name=""
      fi
    done
    sed -i.bak "s/project_name:.*/project_name: ${project_name}/" "$workspace_path/.pilosa/workspace" 2>/dev/null || \
    sed -i '' "s/project_name:.*/project_name: ${project_name}/" "$workspace_path/.pilosa/workspace" 2>/dev/null || true
    rm -f "$workspace_path/.pilosa/workspace.bak"
  fi

  # Read stored source from workspace metadata as default
  if [[ -z "$source_dir" ]]; then
    source_dir="$(grep 'source_location:' "$workspace_path/.pilosa/workspace" 2>/dev/null | sed 's/source_location: *//' | head -1 || echo "")"
    [[ -n "$source_dir" ]] && info "Stored source folder: ${source_dir}"
  fi
  run_integrated_onboarding "$workspace_path" "$project_name" "$source_dir"
  exit 0
}

# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: new
# ═══════════════════════════════════════════════════════════════════════════
# Flow: select corpus root → auto-create sibling workspace → project name → onboard
cmd_new() {
  header "Pilosa — New Workspace"

  local corpus_path=""
  local workspace_path=""
  local new_args
  new_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) die "--force is not supported for pilosa new." ;;
      --numbered) NUMBERED="1"; shift ;;
      --no-color) R="" G="" B="" Y="" C="" M="" DIM="" BOLD="" RESET=""; shift ;;
      --gum)     USE_GUM="1"; shift ;;
      --no-gum)  USE_GUM="0"; shift ;;
      --help|-h)
        printf '  %s\n' "Usage: pilosa new [corpus-directory] [options]"
        printf '    %s\n' "  --numbered   Force numbered menus instead of arrow-key menus"
        printf '    %s\n' "  --no-color   Disable colored output"
        printf '    %s\n' "  --gum        Use interactive Gum prompts"
        printf '    %s\n' "  --no-gum     Use plain shell prompts"
        return 0
        ;;
      *)
        new_args+=("$1")
        shift
        ;;
    esac
  done

  # ── Step 1: Corpus root ────────────────────────────────────────────────
  if [[ -n "${new_args[0]:-}" ]]; then
    corpus_path="$(expand_home "${new_args[0]}")"
  else
    note "Where is your research corpus?"
    note "This is the folder containing your source documents, PDFs, notes, etc."
    note "A sibling workspace folder will be created next to it."
    while true; do
      corpus_path="$(prompt_input "Corpus folder" "" "e.g. ~/Documents/my-research")"
      corpus_path="$(normalize_path_input "$corpus_path")"
      corpus_path="$(expand_home "$corpus_path")"
      if [[ -z "$corpus_path" ]]; then
        printf '  %s\n' "${R}Corpus folder is required.${RESET}" >&2
      elif [[ ! -d "$corpus_path" ]]; then
        printf '  %s\n' "${R}Not a directory: $corpus_path${RESET}" >&2
      else
        break
      fi
    done
  fi

  # Validate corpus
  corpus_path="$(cd "$corpus_path" 2>/dev/null && pwd)"
  ok "Corpus: ${BOLD}${corpus_path}${RESET}"

  # ── Step 2: Auto-generate workspace path ────────────────────────────────
  local corpus_name
  corpus_name="$(basename "$corpus_path")"
  local parent_dir
  parent_dir="$(dirname "$corpus_path")"
  local suffix="-pilosa"
  local candidate="${parent_dir}/${corpus_name}${suffix}"
  local n=1
  while [[ -e "$candidate" ]]; do
    n=$((n + 1))
    candidate="${parent_dir}/${corpus_name}${suffix}-${n}"
  done
  workspace_path="$candidate"
  ok "Workspace: ${BOLD}${workspace_path}${RESET}"

  # ── Step 3: Project name ────────────────────────────────────────────────
  local project_name=""
  local default_name
  default_name="$corpus_name"

  while [[ -z "$project_name" ]] || [[ ! "$project_name" =~ ^[a-zA-Z0-9_ -]+$ ]]; do
    project_name="$(prompt_input "Project name" "$default_name")"
    if [[ -z "$project_name" ]]; then
      :
    elif [[ ! "$project_name" =~ ^[a-zA-Z0-9_ -]+$ ]]; then
      warn "Project name can only contain letters, numbers, spaces, hyphens, and underscores."
      project_name=""
    fi
  done
  project_name="${project_name:-$default_name}"
  ok "Project:   ${BOLD}${project_name}${RESET}"

  # ── Step 4: Create workspace and copy framework ──────────────────────────
  if [[ -z "$FRAMEWORK_ROOT" ]]; then
    die "Framework not found. Is Pilosa installed? Check ${PILOSA_HOME}/versions/"
  fi
  if [[ ! -f "${FRAMEWORK_ROOT}/.pilosa/framework-files.tsv" ]]; then
    die "Framework manifest not found: ${FRAMEWORK_ROOT}/.pilosa/framework-files.tsv"
  fi

  mkdir -p "$workspace_path/.pilosa"

  local source_framework_version
  source_framework_version="$(framework_version "$FRAMEWORK_ROOT")"

  # Copy all framework-owned files
  while IFS=$'\t' read -r path role policy; do
    [[ "$path" == "path" ]] && continue
    is_release_managed_role "$role" || continue

    local src="${FRAMEWORK_ROOT}/${path}"
    local dst="${workspace_path}/${path}"

    if [[ -d "$src" ]]; then
      mkdir -p "$dst"
      cp -a "$src"/. "$dst"/ 2>/dev/null || true
    elif [[ -f "$src" ]]; then
      mkdir -p "$(dirname "$dst")"
      cp -a "$src" "$dst"
    fi
  done < "${FRAMEWORK_ROOT}/.pilosa/framework-files.tsv"

  # Create empty user-state directories with .gitkeep
  for dir in raw maps logs agent_reports .trash; do
    mkdir -p "$workspace_path/$dir"
    touch "$workspace_path/$dir/.gitkeep"
  done
  if [[ ! -f "$workspace_path/logs/session_metrics.tsv" ]]; then
    printf 'date\tsession_id\tagent\troute\toperation\tquery_label\tdirs_seen\tmaps_read\traw_matches\traw_files_read\treports_written\toutput_path\n' > "$workspace_path/logs/session_metrics.tsv"
  fi

  ok "Framework copied"

  # ── Step 5: Write workspace metadata ────────────────────────────────────
  cat > "$workspace_path/.pilosa/workspace" << EOF
workspace_version: 1
framework_version: ${source_framework_version}
created: ${TODAY}
project_name: ${project_name}
source_location: ${corpus_path}
setup_status: not_started
EOF

  # Generate manifest with checksums
  printf 'path\tsha256\n' > "$workspace_path/.pilosa/manifest.tsv"
  while IFS=$'\t' read -r path role policy; do
    [[ "$path" == "path" ]] && continue
    is_release_managed_role "$role" || continue

    local full_path="${workspace_path}/${path}"
    if [[ -f "$full_path" ]]; then
      local hash
      hash="$(sha256_file "$full_path" 2>/dev/null || echo "none")"
      printf '%s\t%s\n' "$path" "$hash" >> "$workspace_path/.pilosa/manifest.tsv"
    elif [[ -d "$full_path" ]]; then
      printf '%s\tdir\n' "$path" >> "$workspace_path/.pilosa/manifest.tsv"
    fi
  done < "${FRAMEWORK_ROOT}/.pilosa/framework-files.tsv"

  ok "Metadata written"

  # Register workspace in global registry
  register_workspace "$workspace_path" "$project_name"

  # ── Step 6: Onboarding (continuous flow) ────────────────────────────────
  run_integrated_onboarding "$workspace_path" "$project_name" "$corpus_path"

  ok "Workspace ready: ${BOLD}${workspace_path}${RESET}"
  printf '\n'
  exit 0
}

# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: update
# ═══════════════════════════════════════════════════════════════════════════
cmd_update() {
  header "Pilosa — Update Workspace"

  local workspace_path=""
  local target_version="latest"
  local release_dir=""
  local dry_run=0
  local auto_yes=0

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --version) target_version="$2"; shift 2 ;;
      --release-dir) release_dir="$(expand_home "$2")"; shift 2 ;;
      --dry-run) dry_run=1; shift ;;
      --yes|-y) auto_yes=1; shift ;;
      --no-color) R="" G="" B="" Y="" C="" M="" DIM="" BOLD="" RESET=""; shift ;;
      --gum)     USE_GUM="1"; shift ;;
      --no-gum)  USE_GUM="0"; shift ;;
      --help|-h)
        printf '  %s\n' "Usage: pilosa update [workspace] [options]"
        printf '    %s\n' "  --version X.Y.Z   Target framework version"
        printf '    %s\n' "  --release-dir DIR Use a local dist/vX.Y.Z directory"
        printf '    %s\n' "  --dry-run         Show what would change without writing"
        printf '    %s\n' "  --yes             Apply the shown plan without confirmation prompts"
        printf '    %s\n' "  --no-color        Disable colored output"
        printf '    %s\n' "  --gum             Use interactive Gum prompts"
        printf '    %s\n' "  --no-gum          Use plain shell confirmations"
        return 0
        ;;
      --*)
        die "Unknown update option: $1. Valid: --version, --release-dir, --dry-run, --yes, --no-color, --gum, --no-gum, --help"
        ;;
      *)
        if [[ -z "$workspace_path" ]]; then
          workspace_path="$(expand_home "$1")"
        else
          die "Unexpected extra workspace argument: $1"
        fi
        shift
        ;;
    esac
  done

  # Resolve workspace path
  if [[ -n "$workspace_path" ]]; then
    workspace_path="$(require_workspace "$workspace_path")" || return $?
  else
    workspace_path="$(require_workspace)" || return $?
  fi
  cd "$workspace_path" || die "Cannot change to workspace: $workspace_path"

  local fw_version project_name
  fw_version="$(grep 'framework_version:' "$workspace_path/.pilosa/workspace" | awk '{print $2}')"
  project_name="$(grep 'project_name:' "$workspace_path/.pilosa/workspace" | sed 's/project_name: *//')"

  ok "Workspace: ${BOLD}${project_name:-unknown}${RESET}"
  info "Current framework version: ${fw_version:-unknown}"

  # Validate manifest exists
  if [[ ! -f "$workspace_path/.pilosa/manifest.tsv" ]]; then
    die "Manifest not found: $workspace_path/.pilosa/manifest.tsv"
  fi

  # ── Load release framework ─────────────────────────────────────────────
  local tmpdir release_info resolved_version release_root release_manifest
  tmpdir="$(mktemp -d)"
  release_info="$(prepare_release_framework "$target_version" "$release_dir" "$tmpdir")"
  resolved_version="${release_info%%$'\t'*}"
  release_root="${release_info#*$'\t'}"
  release_manifest="${release_root}/.pilosa/framework-files.tsv"

  info "Target version: ${resolved_version}"

  # ── Compare checksums ──────────────────────────────────────────────────
  divider
  printf '\n  %sComparing framework files...%s\n\n' "${BOLD}" "${RESET}"

  local modified=0
  local unchanged=0
  local missing=0
  local replaced=0
  local added=0
  local sidecars=0
  local directory_updates=0
  local retired_removed=0
  local retired_kept=0
  local skip_retired_cleanup=0
  local clean_replace_paths
  clean_replace_paths=()
  local forced_replace_paths
  forced_replace_paths=()
  local sidecar_paths
  sidecar_paths=()
  local add_paths
  add_paths=()
  local directory_paths
  directory_paths=()
  local retired_remove_paths
  retired_remove_paths=()
  local retired_keep_paths
  retired_keep_paths=()

  while IFS=$'\t' read -r path role policy; do
    [[ "$path" == "path" ]] && continue
    is_release_managed_role "$role" || continue

    local current_hash stored_hash
    local file_path="${workspace_path}/${path}"
    local src="${release_root}/${path}"
    [[ -e "$src" ]] || continue

    if [[ -d "$src" ]]; then
      directory_paths+=("$path")
      if [[ -d "$file_path" ]]; then
        unchanged=$((unchanged + 1))
      else
        missing=$((missing + 1))
      fi
    elif [[ "$policy" == "always_replace" ]]; then
      if [[ -e "$file_path" ]]; then
        forced_replace_paths+=("$path")
        unchanged=$((unchanged + 1))
      else
        missing=$((missing + 1))
        add_paths+=("$path")
      fi
    elif [[ -f "$file_path" ]]; then
      current_hash="$(sha256_file "$file_path" 2>/dev/null || echo "none")"
      stored_hash="$(manifest_hash "$workspace_path/.pilosa/manifest.tsv" "$path")"

      if [[ "$current_hash" == "$stored_hash" ]]; then
        clean_replace_paths+=("$path")
        unchanged=$((unchanged + 1))
      elif [[ "$current_hash" == "none" ]]; then
        warn "Cannot compute checksum: $path"
      else
        sidecar_paths+=("$path")
        modified=$((modified + 1))
      fi
    else
      missing=$((missing + 1))
      add_paths+=("$path")
    fi
  done < "$release_manifest"

  local retired_manifest="${release_root}/.pilosa/retired-framework-files.tsv"
  if [[ -f "$retired_manifest" ]]; then
    while IFS=$'\t' read -r path reason; do
      [[ "$path" == "path" ]] && continue

      local dst="${workspace_path}/${path}"
      [[ -f "$dst" ]] || continue

      local current_hash stored_hash
      current_hash="$(sha256_file "$dst" 2>/dev/null || echo "none")"
      stored_hash="$(manifest_hash "$workspace_path/.pilosa/manifest.tsv" "$path")"

      if [[ -n "$stored_hash" && "$current_hash" == "$stored_hash" ]]; then
        retired_remove_paths+=("$path")
      else
        retired_keep_paths+=("$path")
      fi
    done < "$retired_manifest"
  fi

  printf '\n'
  info "Workspace user data is not touched: raw corpus files, logs/user_requests.md, context, configuration, dictionary, and workspace index stay in place."
  [[ ${#clean_replace_paths[@]} -gt 0 ]] && print_path_list "Clean framework files to replace" "${clean_replace_paths[@]}"
  [[ ${#forced_replace_paths[@]} -gt 0 ]] && print_path_list "Forced framework files to replace" "${forced_replace_paths[@]}"
  [[ ${#sidecar_paths[@]} -gt 0 ]] && print_path_list "Locally modified framework files to keep with .pilosa-new sidecars" "${sidecar_paths[@]}"
  [[ ${#add_paths[@]} -gt 0 ]] && print_path_list "New framework files to add" "${add_paths[@]}"
  [[ ${#directory_paths[@]} -gt 0 ]] && print_path_list "Framework directories to refresh recursively" "${directory_paths[@]}"
  [[ ${#retired_remove_paths[@]} -gt 0 ]] && print_path_list "Retired clean framework files to remove" "${retired_remove_paths[@]}"
  [[ ${#retired_keep_paths[@]} -gt 0 ]] && print_path_list "Retired modified framework files to leave in place" "${retired_keep_paths[@]}"

  if [[ $modified -gt 0 ]]; then
    warn "Your modified framework files stay unchanged. The release copy is written beside each one as .pilosa-new."
  fi
  if [[ ${#forced_replace_paths[@]} -gt 0 ]]; then
    warn "Forced replacements can overwrite local edits. Keep this policy only for files that must track the framework."
  fi
  if [[ ${#directory_paths[@]} -gt 0 ]]; then
    warn "Directory refreshes copy release contents recursively into existing framework directories."
  fi

  if [[ "$dry_run" -eq 1 ]]; then
    printf '\n  %sDry run — no files changed.%s\n\n' "${DIM}" "${RESET}"
    rm -rf "$tmpdir"
    return 0
  fi

  # ── Confirm ─────────────────────────────────────────────────────────────
  if [[ "$auto_yes" -ne 1 ]]; then
    if [[ ${#sidecar_paths[@]} -gt 0 ]]; then
      if ! confirm_action "Keep local framework edits and write release copies as .pilosa-new sidecars?" "y"; then
        printf '\n  %sUpdate cancelled.%s\n\n' "${DIM}" "${RESET}"
        rm -rf "$tmpdir"
        return 0
      fi
    fi

    if [[ ${#forced_replace_paths[@]} -gt 0 ]]; then
      if ! confirm_action "Replace forced framework files listed above?" "y"; then
        printf '\n  %sUpdate cancelled.%s\n\n' "${DIM}" "${RESET}"
        rm -rf "$tmpdir"
        return 0
      fi
    fi

    if [[ ${#directory_paths[@]} -gt 0 ]]; then
      if ! confirm_action "Refresh framework directories recursively?" "y"; then
        printf '\n  %sUpdate cancelled.%s\n\n' "${DIM}" "${RESET}"
        rm -rf "$tmpdir"
        return 0
      fi
    fi

    if [[ ${#retired_remove_paths[@]} -gt 0 ]]; then
      if ! confirm_action "Remove retired clean framework files listed above?" "y"; then
        skip_retired_cleanup=1
        warn "Retired clean framework files will be left in place."
      fi
    fi

    if ! confirm_action "Apply this Pilosa framework update now?" "y"; then
      printf '\n  %sUpdate cancelled.%s\n\n' "${DIM}" "${RESET}"
      rm -rf "$tmpdir"
      return 0
    fi
  else
    note "--yes supplied: applying the plan without interactive confirmations."
  fi

  # ── Execute update ──────────────────────────────────────────────────────
  divider
  printf '\n  %sApplying update...%s\n\n' "${BOLD}" "${RESET}"

  while IFS=$'\t' read -r path role policy; do
    [[ "$path" == "path" ]] && continue
    is_release_managed_role "$role" || continue

    local src="${release_root}/${path}"
    local dst="${workspace_path}/${path}"

    if [[ -f "$src" ]]; then
      local current_hash stored_hash
      if [[ "$policy" == "always_replace" ]]; then
        mkdir -p "$(dirname "$dst")"
        cp -a "$src" "$dst"
        replaced=$((replaced + 1))
        ok "Replaced: $path"
      elif [[ -f "$dst" ]]; then
        current_hash="$(sha256_file "$dst" 2>/dev/null || echo "none")"
        stored_hash="$(manifest_hash "$workspace_path/.pilosa/manifest.tsv" "$path")"

        if [[ "$current_hash" == "$stored_hash" ]]; then
          # Safe to replace
          cp -a "$src" "$dst"
          replaced=$((replaced + 1))
          ok "Replaced: $path"
        else
          # Conflict — user modified it
          local sidecar
          sidecar="$(next_sidecar_path "$dst")"
          cp -a "$src" "$sidecar"
          sidecars=$((sidecars + 1))
          warn "Conflict: $path → wrote ${sidecar#$workspace_path/}"
        fi
      else
        # New file
        mkdir -p "$(dirname "$dst")"
        cp -a "$src" "$dst"
        added=$((added + 1))
        ok "Added: $path"
      fi
    elif [[ -d "$src" ]]; then
      mkdir -p "$dst"
      cp -a "$src"/. "$dst"/ 2>/dev/null || true
      directory_updates=$((directory_updates + 1))
      ok "Updated: $path/"
    fi
  done < "$release_manifest"

  # ── Remove explicitly retired framework files ───────────────────────────
  if [[ "$skip_retired_cleanup" -eq 0 && -f "$retired_manifest" ]]; then
    while IFS=$'\t' read -r path reason; do
      [[ "$path" == "path" ]] && continue

      local dst="${workspace_path}/${path}"
      [[ -f "$dst" ]] || continue

      local current_hash stored_hash
      current_hash="$(sha256_file "$dst" 2>/dev/null || echo "none")"
      stored_hash="$(manifest_hash "$workspace_path/.pilosa/manifest.tsv" "$path")"

      if [[ -n "$stored_hash" && "$current_hash" == "$stored_hash" ]]; then
        rm -f "$dst"
        retired_removed=$((retired_removed + 1))
        ok "Removed retired: $path"
      else
        retired_kept=$((retired_kept + 1))
        warn "Retired file modified locally, left in place: $path"
      fi
    done < "$retired_manifest"
  fi

  # ── Update manifest ─────────────────────────────────────────────────────
  cp "$workspace_path/.pilosa/manifest.tsv" "$workspace_path/.pilosa/manifest.tsv.bak"
  printf 'path\tsha256\n' > "$workspace_path/.pilosa/manifest.tsv"
  while IFS=$'\t' read -r path role policy; do
    [[ "$path" == "path" ]] && continue
    is_release_managed_role "$role" || continue

    local release_path="${release_root}/${path}"
    local full_path="${workspace_path}/${path}"
    if [[ -f "$release_path" ]]; then
      local current_hash stored_hash release_hash
      release_hash="$(sha256_file "$release_path" 2>/dev/null || echo "none")"
      stored_hash="$(manifest_hash "$workspace_path/.pilosa/manifest.tsv.bak" "$path" 2>/dev/null || true)"
      if [[ "$policy" == "always_replace" || ! -f "$full_path" ]]; then
        printf '%s\t%s\n' "$path" "$release_hash" >> "$workspace_path/.pilosa/manifest.tsv"
      else
        current_hash="$(sha256_file "$full_path" 2>/dev/null || echo "none")"
        if [[ "$current_hash" == "$release_hash" ]]; then
          printf '%s\t%s\n' "$path" "$release_hash" >> "$workspace_path/.pilosa/manifest.tsv"
        else
          # Preserve the old clean hash so unresolved conflicts stay protected.
          printf '%s\t%s\n' "$path" "${stored_hash:-$release_hash}" >> "$workspace_path/.pilosa/manifest.tsv"
        fi
      fi
    elif [[ -d "$release_path" && -d "$full_path" ]]; then
      printf '%s\tdir\n' "$path" >> "$workspace_path/.pilosa/manifest.tsv"
    fi
  done < "$release_manifest"
  rm -f "$workspace_path/.pilosa/manifest.tsv.bak"

  # Update workspace version
  sed -i.bak "s/framework_version: .*/framework_version: ${resolved_version}/" "$workspace_path/.pilosa/workspace" 2>/dev/null || \
  sed -i '' "s/framework_version: .*/framework_version: ${resolved_version}/" "$workspace_path/.pilosa/workspace" 2>/dev/null || true
  rm -f "$workspace_path/.pilosa/workspace.bak"
  rm -rf "$tmpdir"

  divider
  ok "Update complete."
  info "Files replaced: $replaced"
  info "Files added: $added"
  info "Directories updated: $directory_updates"
  info "Retired files removed: $retired_removed"
  [[ $sidecars -gt 0 ]] && warn "Sidecars written: $sidecars"
  [[ $retired_kept -gt 0 ]] && warn "Retired files left in place because they were modified: $retired_kept"
  printf '\n'
}

# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: check
# ═══════════════════════════════════════════════════════════════════════════
cmd_check() {
  local provided_path=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        printf '  %s\n' "Usage: pilosa check [workspace-directory]"
        printf '    %s\n' "  Validates workspace integrity: required files, placeholders,"
        printf '    %s\n' "  setup status, source location, maps, and retrieval coverage."
        return 0
        ;;
      -*) die "Unknown option: $1. Valid: --help" ;;
      *)
        if [[ -n "$provided_path" ]]; then
          die "Unexpected extra argument: $1"
        fi
        provided_path="$1"
        shift
        ;;
    esac
  done
  
  # Resolve workspace path
  local workspace_path
  if [[ -n "$provided_path" ]]; then
    workspace_path="$(require_workspace "$provided_path")" || return $?
  else
    workspace_path="$(require_workspace)" || return $?
  fi
  cd "$workspace_path" || die "Cannot change to workspace: $workspace_path"

  header "Pilosa — Workspace Check"

  local failures
  failures=()
  local warnings
  warnings=()

  # ── required files ────────────────────────────────────────────────
  local required_files
  required_files=(
    "AGENTS.md"
    "system/configuration.md"
    "system/startup.md"
    "system/context.md"
    "system/yaml_header_template.md"
    ".pilosa/framework-files.tsv"
  )
  for file in "${required_files[@]}"; do
    [[ -f "$workspace_path/$file" ]] || failures+=("Missing $file")
  done

  local config startup_text
  config="$(< "$workspace_path/system/configuration.md")"
  local blueprint
  blueprint="$(< "$workspace_path/system/context.md")"
  startup_text="${config}${blueprint}"

  # ── placeholder checks ────────────────────────────────────────────
  for marker in "[path]" "[project name]" "[filled by CLI onboarding]" "[inferred during startup]" "[identified during startup]" "[filled by startup]"; do
    if [[ "$startup_text" == *"$marker"* ]]; then
      failures+=("Required placeholder remains: $marker")
    fi
  done

  # ── setup_status ──────────────────────────────────────────────────
  if [[ "$startup_text" == *"setup_status: cli_started"* ]]; then
    failures+=("setup_status is still cli_started; run the workspace startup agent.")
  fi
  if [[ "$startup_text" != *"setup_status: workspace_started"* ]]; then
    warnings+=("setup_status: workspace_started was not found.")
  fi

  # ── source location ───────────────────────────────────────────────
  local source_path
  source_path="$(echo "$config" | sed -n 's/.*source_location: *["'"'"']*\([^"'"'"']*\)["'"'"']*.*/\1/p' | head -1)"
  if [[ -z "$source_path" || "$source_path" == "[path]" ]]; then
    failures+=("source_location is missing or still a placeholder.")
  else
    local local_path="$source_path"
    [[ ! -d "$local_path" ]] && local_path="$workspace_path/$source_path"
    [[ ! -d "$local_path" ]] && failures+=("Source location does not exist: $source_path")
  fi

  # ── external policy ───────────────────────────────────────────────
  if ! echo "$config" | grep -qE "external_sources_allowed: *(yes|no)"; then
    failures+=("external_sources_allowed is missing or invalid.")
  fi

  # ── workspace index and dictionary ────────────────────────────────
  if [[ "$startup_text" == *"setup_status: workspace_started"* ]]; then
    for required_file in "system/workspace_index.md" "system/dictionary.md"; do
      if [[ ! -f "$workspace_path/$required_file" ]]; then
        failures+=("Missing required file: $required_file")
      elif [[ ! -s "$workspace_path/$required_file" ]]; then
        failures+=("Empty required file: $required_file")
      fi
    done
  fi

  # ── obsidian files ────────────────────────────────────────────────
  if [[ ! -f "$workspace_path/.obsidian/appearance.json" ]]; then
    warnings+=("Missing .obsidian/appearance.json")
  fi
  if [[ ! -d "$workspace_path/.obsidian/snippets" ]]; then
    warnings+=("Missing .obsidian/snippets/")
  fi

  # ── maps validation ────────────────────────────────────────────────
  local maps_dir="$workspace_path/maps"
  if [[ "$startup_text" == *"setup_status: workspace_started"* ]]; then
    if [[ ! -d "$maps_dir" ]]; then
      failures+=("Missing maps directory: maps")
    else
      local has_overview=false
      shopt -s nullglob
      for map_file in "$maps_dir"/*.md; do
        local map_basename="$(basename "$map_file")"
        [[ "$map_basename" == "AGENTS.md" || "$map_basename" == "map_template.md" || "$map_basename" == ".gitkeep" ]] && continue
        has_overview=true
        break
      done
      shopt -u nullglob
      [[ "$has_overview" == "false" ]] && failures+=("No structural overview map found at maps/ root")

      local has_groups=false
      shopt -s nullglob
      for dir in "$maps_dir"/*/; do
        local dir_name="$(basename "$dir")"
        [[ "$dir_name" == ".gitkeep" ]] && continue
        has_groups=true
        break
      done
      shopt -u nullglob
      [[ "$has_groups" == "false" ]] && failures+=("No group map subdirectories found under maps/")
    fi
  fi

  # ── output ─────────────────────────────────────────────────────────
  if [[ ${#failures[@]} -gt 0 ]]; then
    divider
    printf '%s\n' "${BOLD}${R}Check failed:${RESET}"
    for f in "${failures[@]}"; do
      printf '  %s %s\n' "${R}✗${RESET}" "$f"
    done
    if [[ ${#warnings[@]} -gt 0 ]]; then
      printf '\n%s\n' "${BOLD}${Y}Warnings:${RESET}"
      for w in "${warnings[@]}"; do
        printf '  %s %s\n' "${Y}⚠${RESET}" "$w"
      done
    fi
    printf '\n'
    return 1
  fi

  divider
  ok "Check passed."
  if [[ ${#warnings[@]} -gt 0 ]]; then
    printf '\n%s\n' "${BOLD}${Y}Warnings:${RESET}"
    for w in "${warnings[@]}"; do
      printf '  %s %s\n' "${Y}⚠${RESET}" "$w"
    done
  fi
  printf '\n'
}

# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: sync
# ═══════════════════════════════════════════════════════════════════════════
cmd_sync() {
  local dry_run=0 auto_yes=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run=1; shift ;;
      --yes|-y)  auto_yes=1; shift ;;
      --help|-h)
        echo "Usage: pilosa sync [options]" >&2
        echo "  --dry-run   Show what would change without writing" >&2
        echo "  --yes       Skip confirmation prompt" >&2
        return 0
        ;;
      -*) die "Unknown sync option: $1. Valid: --dry-run, --yes, --help" ;;
      *) shift ;;
    esac
  done

  # Use FRAMEWORK_ROOT (resolves dev + installed mode correctly)
  local repo_root="$FRAMEWORK_ROOT"
  if [[ -z "$repo_root" || ! -d "$repo_root/.agents/agents" ]]; then
    die "Framework root not found. Cannot sync without framework."
  fi

  header "Pilosa — Sync Agents & Skills"

  local agents_src="$repo_root/.agents/agents"
  local skills_src="$repo_root/.agents/skills"

  if [[ ! -d "$agents_src" ]]; then
    die "Canonical agents directory not found: $agents_src"
  fi

  # Count what will change
  local agent_count=0
  for canonical in "$agents_src"/*.md; do
    [[ -f "$canonical" ]] && agent_count=$((agent_count + 1))
  done
  local skill_count=0
  for skill_dir in "$skills_src"/*/; do
    [[ -d "$skill_dir" ]] && skill_count=$((skill_count + 1))
  done

  info "Will sync ${agent_count} agents and ${skill_count} skills"
  info "Targets: .opencode/agents/, .claude/agents/, .codex/agents/"
  info "Skills:  .opencode/skills/, .claude/skills/, .codex/skills/"

  if [[ "$dry_run" -eq 1 ]]; then
    warn "Dry run — no changes made"
    return 0
  fi

  if [[ "$auto_yes" -ne 1 ]]; then
    printf '\n'
    if ! confirm "Apply sync? (deletes and regenerates vendor agent files)" "y"; then
      info "Sync cancelled."
      return 0
    fi
  fi

  # ── clean stale mirrors ────────────────────────────────────────────
  info "Cleaning stale mirrors..."
  rm -rf "$repo_root/.opencode/skills" 2>/dev/null || true

  # ── ensure destination directories ─────────────────────────────────
  mkdir -p "$repo_root/.opencode/agents"
  mkdir -p "$repo_root/.claude/agents"
  mkdir -p "$repo_root/.codex/agents"

  # ── clean existing vendor agent files ──────────────────────────────
  rm -f "$repo_root/.opencode/agents/"*.md
  rm -f "$repo_root/.claude/agents/"*.md
  rm -f "$repo_root/.codex/agents/"*.toml

  # ── sync agent definitions ─────────────────────────────────────────
  local agent agent_file name description permissions opencode_perms frontmatter
  local claude_tools canonical perm_part key val count=0 body_content

  toml_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
  }

  for canonical in "$agents_src"/*.md; do
    [[ -f "$canonical" ]] || continue
    agent_file="$(basename "$canonical")"
    agent="${agent_file%.md}"

    frontmatter="$(sed -n '/^---$/,/^---$/p' "$canonical" | sed '1d;$d')"
    name="$(echo "$frontmatter" | sed -n 's/^name: *//p' | head -1)"
    description="$(sed -n '/^description: |/,/^[a-z]/p' "$canonical" | sed '/^description:/d;/^[a-z]/d' | sed 's/^  //' | tr -s ' ')"
    [[ -z "$description" ]] && description="$agent"

    permissions=""
    local in_perm=false
    while IFS= read -r line; do
      if $in_perm && [[ "$line" == "---" ]]; then break; fi
      if [[ "$line" =~ ^permissions: ]]; then in_perm=true; continue; fi
      if $in_perm; then
        if [[ "$line" =~ ^[a-z] ]] && ! [[ "$line" =~ ^[[:space:]] ]]; then break; fi
        [[ "$line" =~ ^[[:space:]]*-[[:space:]] ]] && continue
        if [[ "$line" =~ ^[[:space:]]*([a-z]+):[[:space:]]*(.*) ]]; then
          key="${BASH_REMATCH[1]}"; value="${BASH_REMATCH[2]}"
          [[ -z "$value" ]] && value="allow"
          permissions="$permissions$key: $value, "
        fi
      fi
    done < "$canonical"
    permissions="${permissions%, }"

    # ── OpenCode agent ──────────────────────────────────────────────
    opencode_perms=""
    IFS=',' read -ra perm_parts <<< "$permissions"
    for part in "${perm_parts[@]}"; do
      part="${part## }"; part="${part%% }"
      [[ -z "$part" ]] && continue
      key="${part%%:*}"; val="${part#*: }"
      case "$key" in
        read|grep|glob) opencode_perms="$opencode_perms  $key: $val"$'\n' ;;
        write) opencode_perms="$opencode_perms  edit: $val"$'\n' ;;
        move) opencode_perms="$opencode_perms  bash: $val"$'\n' ;;
      esac
    done

    body_content="$(awk 'BEGIN{fm=0} /^---$/ && fm < 2 {fm++; next} fm == 2' "$canonical")"

    cat > "$repo_root/.opencode/agents/$agent_file" << OPENCODE_EOF
---
name: $name
description: |
$(echo "$description" | sed 's/^/  /')
mode: subagent
permission:
$(echo "$opencode_perms" | sed '$d')
---

$body_content
OPENCODE_EOF

    # ── Claude agent ─────────────────────────────────────────────────
    case "$agent" in
      pilosa-searcher)    claude_tools="Read, Grep, Glob" ;;
      pilosa-analyst)     claude_tools="Read" ;;
      pilosa-writer)      claude_tools="Read, Write" ;;
      pilosa-verifier)    claude_tools="Read, Grep, Glob, Write" ;;
      pilosa-janitor)     claude_tools="Read, Grep, Glob, Write" ;;
      pilosa-mapper)      claude_tools="Read, Write" ;;
      pilosa-serendippo)  claude_tools="Read, Grep, Glob, Write" ;;
    esac

    cat > "$repo_root/.claude/agents/$agent_file" << CLAUDE_EOF
---
name: $name
description: |
$(echo "$description" | sed 's/^/  /')
tools: $claude_tools
---

$body_content
CLAUDE_EOF

    cat > "$repo_root/.codex/agents/${agent}.toml" << CODEX_EOF
name = "$(toml_escape "$name")"
description = "$(toml_escape "$description")"
developer_instructions = '''
$body_content
'''
CODEX_EOF

    count=$((count + 1))
    ok "Synced $agent"
  done

  # ── sync skills ────────────────────────────────────────────────────
  for platform in .opencode .claude .codex; do
    local dest="$repo_root/$platform/skills"
    rm -rf "$dest"
    mkdir -p "$dest"
    for skill_dir in "$skills_src"/*/; do
      [[ -d "$skill_dir" ]] || continue
      local skill_name="$(basename "$skill_dir")"
      mkdir -p "$dest/$skill_name"
      cp "$skill_dir"*.md "$dest/$skill_name/" 2>/dev/null || true
      if [[ -d "$skill_dir/references" ]]; then
        mkdir -p "$dest/$skill_name/references"
        cp "$skill_dir/references/"*.md "$dest/$skill_name/references/" 2>/dev/null || true
      fi
    done
    local skill_count
    skill_count="$(find "$dest" -name "SKILL.md" | wc -l | tr -d ' ')"
    ok "Synced $skill_count skills to $platform/skills/"
  done

  # ── sync CLAUDE.md ──────────────────────────────────────────────────
  cp "$repo_root/AGENTS.md" "$repo_root/CLAUDE.md"
  local today
  today="$(date +%Y-%m-%d)"
  # Update updated date and add provenance fields in the frontmatter block
  sed -i.bak \
    -e 's/^updated:.*/updated: '"$today"'/' \
    -e '/^updated:/a\'$'\n''generated_by: sync-agents\'$'\n''generated_at: '"$today"''$'\n''processing_status: auto_generated' \
    "$repo_root/CLAUDE.md" 2>/dev/null || \
  sed -i '' \
    -e 's/^updated:.*/updated: '"$today"'/' \
    -e '/^updated:/a\
generated_by: sync-agents\
generated_at: '"$today"'\
processing_status: auto_generated' \
    "$repo_root/CLAUDE.md" 2>/dev/null || true
  rm -f "$repo_root/CLAUDE.md.bak"
  ok "Synced CLAUDE.md"

  divider
  ok "Sync complete — $count agents, skills mirrored to 3 platforms."
  printf '\n'
}

