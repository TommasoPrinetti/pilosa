- Source location: ${source_path} (already validated, files transposed to raw/ — Office docs converted via MarkItDown, scanned PDFs and images via RapidOCR OCR, videos/audio/AGENTS.md skipped)
- Preferred LLM CLI: ${preferred_cli}

Optional context not collected by fast setup:
- Project description (if absent, infer from the raw corpus)
- Helpful artifact URLs or file paths (if absent, record none provided)
- External source policy defaults to no; ask only if external URL access is needed or the user requests external sources.

Then execute system/startup.md. Specifically:
- Phase 1: Verify onboarding completed (setup files exist, source location valid)
- Phase 2: Index, Map, Validate — build the master dictionary, extract content-grounded fragments, generate YAML headers, write multi-level navigation maps, run serendipitous connection discovery, update workspace_index.md, run validation and retrieval tests
- Set setup_status to workspace_started in both system/context.md and system/configuration.md
- Write the startup report to agent_reports/

Do not re-ask questions the CLI draft already answered. Do not stop after one index. Do not edit the source location or \`raw/\`.
PROMPT_EOF
}

# ── OCR User Prompt ────────────────────────────────────────────────────────────

# ── RapidOCR Functions ────────────────────────────────────────────────────────

PILOSA_VENDOR_DIR="${PILOSA_HOME:-$HOME/.pilosa}/vendor/pilosa"
RAPIDOCR_VENDOR_DIR="${PILOSA_HOME:-$HOME/.pilosa}/vendor/rapidocr"
PLATFORM="${OS:-$(uname -s | tr '[:upper:]' '[:lower:]')}-$(uname -m | sed 's/aarch64/arm64/')"
RAPIDOCR_PLATFORM="$PLATFORM"

rapidocr_ocr_available() {
  # Unified vendor path (post-merger)
  local unified_bin="${PILOSA_VENDOR_DIR}-${PLATFORM}/rapidocr-cli"
  [[ -x "$unified_bin" ]] && return 0
  # Legacy vendor path (pre-merger)
  local bin="${RAPIDOCR_VENDOR_DIR}/${RAPIDOCR_PLATFORM}/rapidocr-cli"
  [[ -x "$bin" ]] && return 0
  # Framework .bin/lib/vendor/ directory
  local framework_unified="${FRAMEWORK_ROOT:-.}/.bin/lib/vendor/pilosa-${PLATFORM}/rapidocr-cli"
  [[ -x "$framework_unified" ]] && return 0
  local framework_bin="${FRAMEWORK_ROOT:-.}/.bin/lib/vendor/rapidocr-${RAPIDOCR_PLATFORM}/rapidocr-cli"
  [[ -x "$framework_bin" ]] && return 0
  return 1
}

rapidocr_ocr_bin() {
  local unified_bin="${PILOSA_VENDOR_DIR}-${PLATFORM}/rapidocr-cli"
  if [[ -x "$unified_bin" ]]; then echo "$unified_bin"; return; fi
  local bin="${RAPIDOCR_VENDOR_DIR}/${RAPIDOCR_PLATFORM}/rapidocr-cli"
  if [[ -x "$bin" ]]; then echo "$bin"; return; fi
  local framework_unified="${FRAMEWORK_ROOT:-.}/.bin/lib/vendor/pilosa-${PLATFORM}/rapidocr-cli"
  if [[ -x "$framework_unified" ]]; then echo "$framework_unified"; return; fi
  local framework_bin="${FRAMEWORK_ROOT:-.}/.bin/lib/vendor/rapidocr-${RAPIDOCR_PLATFORM}/rapidocr-cli"
  if [[ -x "$framework_bin" ]]; then echo "$framework_bin"; return; fi
  return 1
}

# ── MarkItDown Functions ────────────────────────────────────────────────────

markitdown_available() {
  local unified_bin="${PILOSA_VENDOR_DIR}-${PLATFORM}/markitdown-cli"
  [[ -x "$unified_bin" ]] && return 0
  local framework_bin="${FRAMEWORK_ROOT:-.}/.bin/lib/vendor/pilosa-${PLATFORM}/markitdown-cli"
