run_cli_with_prompt() {
  local root="$1" cli="$2" prompt="$3"
  case "$cli" in
    codex)
      command -v codex >/dev/null 2>&1 || { warn "codex was not found on PATH."; return 1; }
      if [[ "$(uname)" == "Darwin" ]]; then
        local _ptmp_codex _ltmp_codex
