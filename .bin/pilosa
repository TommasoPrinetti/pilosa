# WORKSPACE DISCOVERY & CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

PILOSA_CONFIG="${PILOSA_HOME}/config.yaml"
PILOSA_CACHE="${PILOSA_HOME}/workspace_cache.txt"
DEFAULT_SCAN_ROOTS=("$HOME/Projects" "$HOME/Work" "$HOME/Documents")
CACHE_TTL=3600  # 1 hour

# Load config from ~/.pilosa/config.yaml
load_config() {
  SCAN_PERMISSION="unknown"
  SCAN_ROOTS=("${DEFAULT_SCAN_ROOTS[@]}")
  
  [[ -f "$PILOSA_CONFIG" ]] || return 0
  
  while IFS= read -r line; do
    if [[ "$line" == scan_permission:* ]]; then
      SCAN_PERMISSION="${line#scan_permission: }"
      SCAN_PERMISSION="${SCAN_PERMISSION//\"/}"
    elif [[ "$line" == scan_roots:* ]]; then
      # Next lines will be the roots
      :
    elif [[ "$line" == "  - "* ]]; then
      if [[ -z "$SCAN_PERMISSION" ]]; then
        continue
      fi
      local root="${line#  - }"
      root="${root//\"/}"
      root="${root//\~/$HOME}"
      SCAN_ROOTS+=("$root")
    fi
  done < "$PILOSA_CONFIG"
  
  # Set defaults if not found
  [[ -z "$SCAN_PERMISSION" ]] && SCAN_PERMISSION="unknown" || true
  [[ ${#SCAN_ROOTS[@]} -eq 0 ]] && SCAN_ROOTS=("${DEFAULT_SCAN_ROOTS[@]}") || true
}

# Save config to ~/.pilosa/config.yaml
save_config() {
  local permission="${1:-unknown}"
  shift
  local roots=("$@")
  
  mkdir -p "$PILOSA_HOME"
  
  {
    echo "scan_permission: \"$permission\""
    echo "scan_roots:"
    for root in "${roots[@]}"; do
      echo "  - \"$root\""
    done
  } > "$PILOSA_CONFIG"
}

# Ask permission on first run
ask_scan_permission() {
  printf '\n%s\n' "${BOLD}Pilosa needs to discover your workspaces.${RESET}"
  printf '\n%s\n' "Scan common directories (~/Projects, ~/Work, ~/Documents) for Pilosa workspaces?"
  printf '%s\n' "This runs \`find\` with maxdepth 3 and caches results for 1 hour."
  printf '\n'
  
  if confirm "Allow workspace discovery?" "y"; then
    save_config "granted" "${DEFAULT_SCAN_ROOTS[@]}"
    return 0
  else
    save_config "denied" "${DEFAULT_SCAN_ROOTS[@]}"
    return 1
  fi
}

# Check if cache is fresh (< TTL)
cache_is_fresh() {
  [[ -f "$PILOSA_CACHE" ]] || return 1
  
  local cache_time
  cache_time="$(stat -f %m "$PILOSA_CACHE" 2>/dev/null || stat -c %Y "$PILOSA_CACHE" 2>/dev/null || echo 0)"
  local current_time
  current_time="$(date +%s)"
  local age=$((current_time - cache_time))
  
  [[ $age -lt $CACHE_TTL ]]
}

# Scan workspaces and return paths
scan_workspaces() {
  local roots=("$@")
  local seen=()
  
  # Handle empty roots array
  [[ ${#roots[@]} -gt 0 ]] || return 0
  
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' ws_file; do
      local ws_dir
      ws_dir="$(cd "$(dirname "$(dirname "$ws_file")")" && pwd)"
      local already_seen=0
      for s in "${seen[@]}"; do
        [[ "$s" == "$ws_dir" ]] && { already_seen=1; break; }
      done
      [[ "$already_seen" == "0" ]] || continue
      seen+=("$ws_dir")
      printf '%s\n' "$ws_dir"
    done < <(find "$root" -maxdepth 3 -name "workspace" -path "*/.pilosa/workspace" -print0 2>/dev/null)
  done
}

# Update cache with discovered workspaces
update_cache() {
  local workspaces=("$@")
  
  mkdir -p "$PILOSA_HOME"
  
  {
    for ws in "${workspaces[@]}"; do
      local project
      project="$(grep 'project_name:' "$ws/.pilosa/workspace" 2>/dev/null | sed 's/project_name: *//' | head -1)"
      echo "$ws|$project"
    done
  } > "$PILOSA_CACHE"
}

# Load workspaces from cache
load_cached_workspaces() {
  [[ -f "$PILOSA_CACHE" ]] || return 1
  
  while IFS='|' read -r path project; do
    [[ -d "$path/.pilosa" ]] || continue  # Validate still exists
    printf '%s|%s\n' "$path" "$project"
  done < "$PILOSA_CACHE"
}

# Main discovery function with permission and caching
# Note: This function does NOT ask for permission - caller must handle that
discover_workspaces_with_permission() {
  load_config
  
  # Check permission (don't ask, just check)
  if [[ "$SCAN_PERMISSION" != "granted" ]]; then
    return 1
  fi
  
  # Try registry first (instant)
  if load_registry; then
    return 0
  fi
  
  # Fallback to scan
  local workspaces=()
  while IFS= read -r ws; do
    [[ -n "$ws" ]] && workspaces+=("$ws")
  done < <(scan_workspaces "${SCAN_ROOTS[@]}")
  
  # Update both cache and registry (only if workspaces found)
  if [[ ${#workspaces[@]} -gt 0 ]]; then
    update_cache "${workspaces[@]}"
    update_registry "${workspaces[@]}"
  fi
  
  # Return results
  if [[ ${#workspaces[@]} -gt 0 ]]; then
    for ws in "${workspaces[@]}"; do
      local project
      project="$(grep 'project_name:' "$ws/.pilosa/workspace" 2>/dev/null | sed 's/project_name: *//' | head -1)"
      printf '%s|%s\n' "$ws" "$project"
    done
  fi
}

# Load workspaces from persistent registry
load_registry() {
  local registry="${PILOSA_HOME}/workspaces.txt"
  [[ -f "$registry" ]] || return 1
  
  local found=0
  while IFS='|' read -r path project created; do
    [[ -d "$path/.pilosa" ]] || continue  # Validate still exists
    printf '%s|%s\n' "$path" "$project"
    found=1
  done < "$registry"
  
  [[ $found -eq 1 ]]
}

# Register a workspace in the persistent registry
register_workspace() {
  local path="$1"
  local project="${2:-}"
  local registry="${PILOSA_HOME}/workspaces.txt"
  
  mkdir -p "$PILOSA_HOME"
  
  # Remove if already exists
  if [[ -f "$registry" ]]; then
    grep -v "^${path}|" "$registry" > "${registry}.tmp" 2>/dev/null || true
    mv "${registry}.tmp" "$registry"
  fi
  
  # Add new entry
  echo "${path}|${project}|$(date +%Y-%m-%d)" >> "$registry"
}

# Update registry with discovered workspaces
update_registry() {
  local workspaces=("$@")
  local registry="${PILOSA_HOME}/workspaces.txt"
  
  mkdir -p "$PILOSA_HOME"
  
  for ws in "${workspaces[@]}"; do
    local project
    project="$(grep 'project_name:' "$ws/.pilosa/workspace" 2>/dev/null | sed 's/project_name: *//' | head -1)"
    # Only add if not already in registry
    if ! grep -q "^${ws}|" "$registry" 2>/dev/null; then
      echo "${ws}|${project}|$(date +%Y-%m-%d)" >> "$registry"
    fi
  done
}

# Legacy function for backward compatibility
discover_workspaces() {
  discover_workspaces_with_permission | cut -d'|' -f1
}

# Validate workspace path
validate_workspace() {
  local path="$1"
  [[ -d "$path" ]] || return 1
  [[ -f "$path/.pilosa/workspace" ]] || return 1
  return 0
}

# Prompt for workspace path with escape option
prompt_workspace_or_cancel() {
  local hint="(Enter workspace path, Esc to go back)"
  while true; do
    local manual_path
    manual_path="$(prompt_input "Workspace path" "" "$hint")"
    # Esc → cancel
    [[ "$manual_path" != $'\e'* ]] || return 1
    [[ -n "$manual_path" ]] || continue
    manual_path="$(expand_home "$manual_path")"
    if ! validate_workspace "$manual_path"; then
      printf '%s\n' "${R}Not a valid Pilosa workspace: $manual_path${RESET}" >&2
      continue
    fi
    echo "$manual_path"
    return 0
  done
}

# Main helper - returns workspace path or prompts for selection
require_workspace() {
  local provided_path="${1:-}"
  
  # If path provided, validate it
  if [[ -n "$provided_path" ]]; then
    provided_path="$(expand_home "$provided_path")"
    if validate_workspace "$provided_path"; then
      echo "$provided_path"
      return 0
    else
      die "Not a valid Pilosa workspace: $provided_path"
    fi
  fi
  
  # Not in a workspace - discover and prompt
  local discovered=()
  local workspace_data
  
  spinner_start "Discovering workspaces"
  workspace_data="$(discover_workspaces_with_permission 2>/dev/null)"
  spinner_stop
  
  if [[ -z "$workspace_data" ]]; then
    printf '\n%s\n' "${Y}Not in a Pilosa workspace.${RESET}" >&2
    prompt_workspace_or_cancel || return 1
    return 0
  fi
  
  # Parse discovered workspaces
  while IFS='|' read -r ws_path project; do
    [[ -n "$ws_path" ]] && discovered+=("$ws_path|$project")
  done <<< "$workspace_data"
  
  if [[ ${#discovered[@]} -eq 0 ]]; then
    # No valid workspaces - prompt for path
    prompt_workspace_or_cancel || return 1
    return 0
  fi
  
  # Build options for selection
  local options=()
  for entry in "${discovered[@]}"; do
    local ws_path="${entry%%|*}"
    local project="${entry#*|}"
    local ws_name
    ws_name="$(basename "$ws_path")"
    
    if [[ -n "$project" ]]; then
      options+=("$(option_spec "$ws_path" "$ws_name" "$project")")
    else
      options+=("$(option_spec "$ws_path" "$ws_path" "")")
    fi
  done
  options+=("$(option_spec "__scan__" "Find other workspaces" "scan directories for workspaces")")
  options+=("$(option_spec "__enter__" "Enter path manually" "type a workspace path")")
  
  local choice
  choice="$(prompt_choose "Select a workspace" "${options[@]}")" || return 1
  
  if [[ "$choice" == "__scan__" ]]; then
    spinner_start "Scanning for workspaces"
    local scanned=()
    while IFS= read -r ws; do
      [[ -n "$ws" ]] && scanned+=("$ws")
    done < <(scan_workspaces "${SCAN_ROOTS[@]}")
    spinner_stop
    
    local new_count=0
    for ws in "${scanned[@]}"; do
      if ! grep -q "^${ws}|" "${PILOSA_HOME}/workspaces.txt" 2>/dev/null; then
        new_count=$((new_count + 1))
      fi
    done
    
    update_registry "${scanned[@]}"
    
    if [[ $new_count -gt 0 ]]; then
      ok "Found ${new_count} new workspace(s), registry updated"
    else
      info "No new workspaces found"
    fi
    
    # Re-prompt with updated list
    exec "$0" "${ORIGINAL_ARGS[@]}"
  elif [[ "$choice" == "__enter__" ]]; then
    local manual_path
    manual_path="$(prompt_input "Workspace path")"
    [[ -n "$manual_path" ]] || die "Path is required"
    manual_path="$(expand_home "$manual_path")"
    if ! validate_workspace "$manual_path"; then
      die "Not a valid Pilosa workspace: $manual_path"
    fi
    echo "$manual_path"
  else
    echo "$choice"
  fi
}

