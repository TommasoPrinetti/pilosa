run_rapidocr_ocr() {
  local input_file="$1" output_file="$2"
  local ocr_bin
  ocr_bin="$(rapidocr_ocr_bin)" || { echo "ERROR: RapidOCR not installed" >&2; return 1; }
  "$ocr_bin" "$input_file" "$output_file"
}

is_rapidocr_image() {
  local ext
  ext="$(file_ext "$1")"
  [[ -n "$ext" ]] && ext_in_list "$ext" "$IMAGE_EXTENSIONS"
}

is_rapidocr_pdf() {
  local ext
  ext="$(file_ext "$1")"
  [[ -n "$ext" ]] && ext_in_list "$ext" "pdf"
}

# ── Image File Detection ──────────────────────────────────────────────────────

IMAGE_EXTENSIONS="jpg|jpeg|png|gif|webp|heic|heif|tif|tiff|bmp|svg"

prompt_ocr_choice() {
  # Skip OCR prompt in non-interactive mode (piped input, CI, tests)
  if [[ ! -t 0 ]]; then
    SCAN_OCR_CHOICE="no"
    return 0
  fi

  local total_ocr="${SCAN_OCR_CONVERTIBLE_COUNT:-0}"
  
  # Skip if no scanned PDFs or images
  [[ "$total_ocr" -gt 0 ]] || { SCAN_OCR_CHOICE="no"; return 0; }
  
  if rapidocr_ocr_available; then
    echo ""
    note "OCR Available: RapidOCR (bundled)"
    note "  • Converts scanned PDFs → structured Markdown via off-line OCR"
    note "  • Converts images → text via OCR (90+ languages)"
    note "  • Runs 100% locally, no cloud needed"
    note "  • Text-based PDFs are handled by MarkItDown (faster text extraction)"
    echo ""
    
    if confirm "Would you like to OCR ${total_ocr} scanned PDFs and images?"; then
      SCAN_OCR_CHOICE="yes"
    else
      SCAN_OCR_CHOICE="no"
      echo ""
      warn "Skipping OCR: ${total_ocr} files will not be processed"
    fi
  else
    warn "RapidOCR OCR not available for this platform"
    SCAN_OCR_CHOICE="no"
  fi
}

run_integrated_onboarding() {
  local root="$1" project_title="$2" preselected_source="${3:-}"
  local source_path="" preferred_cli preferred_cli_label startup_prompt launch_command handoff_action handoff_action_text handoff_result
  local copyable_count estimated_bytes free_bytes scan_action source_prompt_shown=0

  # ── Step 1: Source folder ─────────────────────────────────────────────
  if [[ -n "$preselected_source" ]]; then
    source_path="$preselected_source"
    info "Source: ${BOLD}${source_path}${RESET}"
  fi

  while true; do
    if [[ -z "$source_path" ]]; then
      print_step 1 3 "Source files folder"
      if [[ "$source_prompt_shown" -eq 0 ]]; then
        note "Specify the folder containing your research materials (documents, PDFs, notes)."
        note "These files will be copied into the workspace for analysis."
        note "Nothing in the original folder is moved, renamed, or edited."
      else
        note "Choose another source folder and Pilosa will rescan it before writing anything."
      fi
      source_prompt_shown=1

      while true; do
        source_path="$(prompt_directory "Source folder (absolute path)" "${preselected_source:-}" "e.g. /home/user/Documents/my-sources")"
        source_path="$(normalize_path_input "$source_path")"
        source_path="$(expand_home "$source_path")"
        if [[ -z "$source_path" ]]; then
          printf '  %s\n' "${R}Source folder is required.${RESET}" >&2
        elif [[ ! -d "$source_path" ]]; then
          printf '  %s\n' "${R}Source folder does not exist: $source_path${RESET}" >&2
        else
          break
        fi
      done
      ok "Source: ${BOLD}${source_path}${RESET}"
    fi

    print_step 2 3 "Corpus scan and consent"
    print_onboarding_preflight "$root"
    scan_source "$source_path"
    print_scan_summary

    choose_import_batches || return 1

    # Auto-detect MarkItDown from selected extensions
    SCAN_MARKITDOWN_CHOICE="no"
    if markitdown_available; then
      local _md_ext
      for _md_ext in "${SELECTED_IMPORT_EXTENSIONS[@]}"; do
        if [[ "$_md_ext" == "pdf" ]] || ext_in_list "$_md_ext" "$MARKITDOWN_EXTENSIONS"; then
          SCAN_MARKITDOWN_CHOICE="yes"
          break
        fi
      done
    fi

    # Auto-detect OCR from selected extensions (images, and PDFs only if MarkItDown unavailable)
    SCAN_OCR_CHOICE="no"
    if rapidocr_ocr_available; then
      local _ext
      for _ext in "${SELECTED_IMPORT_EXTENSIONS[@]}"; do
        if ext_in_list "$_ext" "$IMAGE_EXTENSIONS"; then
          SCAN_OCR_CHOICE="yes"
          break
        fi
        if [[ "$_ext" == "pdf" ]] && ! markitdown_available; then
          SCAN_OCR_CHOICE="yes"
          break
        fi
      done
    fi

    copyable_count="$(selected_import_count)"
    estimated_bytes="$(scan_copyable_bytes)"
    free_bytes="$(available_disk_bytes "$root")"
    if [[ "$free_bytes" -gt 0 ]]; then
      if (( estimated_bytes > free_bytes )); then
        warn "Estimated import size is $(format_bytes "$estimated_bytes"), but only $(format_bytes "$free_bytes") is free near the workspace."
      else
        note "Estimated import size: $(format_bytes "$estimated_bytes")"
      fi
    fi

    echo ""
    if [[ "$copyable_count" -gt 0 ]]; then
      note "Ready to import ${copyable_count} files into the workspace. This does not modify your source."
      note "Selected file types: $(selected_import_extensions_label)"
    else
      warn "No file types are selected for import."
    fi
    echo ""

    [[ "$copyable_count" -gt 0 ]] || { warn "No workspace copy was prepared. Onboarding stopped after the scan."; return 1; }
    break
  done

  copy_source "$source_path" "$root/raw"

  print_step 3 3 "Startup handoff"
  reset_terminal
  preferred_cli="$(choose_preferred_cli)" || return 1
  preferred_cli_label="$(preferred_cli_name "$preferred_cli")"
  ok "CLI: ${BOLD}${preferred_cli_label}${RESET}"

  write_setup_files "$root" "$project_title" "$source_path" "$preferred_cli_label"
  sed -i.bak 's/setup_status: not_started/setup_status: cli_started/' "$root/.pilosa/workspace" 2>/dev/null || \
  sed -i '' 's/setup_status: not_started/setup_status: cli_started/' "$root/.pilosa/workspace" 2>/dev/null || true
  rm -f "$root/.pilosa/workspace.bak"

  startup_prompt="$(startup_prompt_text "$project_title" "$source_path" "$preferred_cli_label")"
  launch_command="$(build_launch_command "$root" "$preferred_cli" "$startup_prompt")"

  print_box "Pilosa Startup Prompt Preview" <<< "$(prompt_preview <<< "$startup_prompt")"
  print_box "Terminal Launch Command Preview" <<< "$(prompt_preview <<< "$launch_command")"

  handoff_action="$(choose_handoff_action)" || return 1
  handoff_action_text="$(handoff_action_label "$handoff_action")"
  handoff_result="launch_command_copied"
  if [[ "$handoff_action" == "run_now" ]]; then
    run_cli_with_prompt "$root" "$preferred_cli" "$startup_prompt" || {
      handoff_result="run_failed_command_copied"
      warn "Could not run ${preferred_cli_label}. Copying the launch command instead."
      copy_to_clipboard "$launch_command" && ok "Launch command copied to your clipboard." || print_box "Terminal Launch Command — full text" <<< "$launch_command"
    }
    [[ "$handoff_result" != "run_failed_command_copied" ]] && handoff_result="run_requested"
  else
    copy_to_clipboard "$launch_command" && ok "Launch command copied to your clipboard." || print_box "Terminal Launch Command — full text" <<< "$launch_command"
  fi

  write_onboarding_summary "$root" "$project_title" "$source_path" "$preferred_cli_label" "$handoff_action_text" "$handoff_result"
}

# ── framework manifest reader ──────────────────────────────────────────────
# Reads framework-files.tsv and returns paths matching the given role filter.
# Usage: read_manifest [framework|user_state|mixed_framework_user]
read_manifest() {
  local filter="${1:-}"
  local tsv="${FRAMEWORK_ROOT}/.pilosa/framework-files.tsv"
  [[ -f "$tsv" ]] || die "Framework manifest not found: $tsv"

  while IFS=$'\t' read -r path role policy; do
    [[ "$path" == "path" ]] && continue  # skip header
    if [[ -z "$filter" || "$role" == "$filter" ]]; then
      echo "$path"
    fi
  done < "$tsv"
}

# ── detect installed LLM CLIs ──────────────────────────────────────────────
detect_llm_clis() {
  local clis
  clis=()
  command -v claude >/dev/null 2>&1 && clis+=("Claude Code")
  command -v codex >/dev/null 2>&1 && clis+=("Codex")
  command -v opencode >/dev/null 2>&1 && clis+=("OpenCode")
  command -v kilo >/dev/null 2>&1 && clis+=("Kilo")
  if [[ ${#clis[@]} -eq 0 ]]; then
    clis+=("Other (manual)")
  fi
  printf '%s\n' "${clis[@]}"
}

