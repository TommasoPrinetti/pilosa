cmd_health() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        printf '  %s\n' "Usage: pilosa health"
        printf '    %s\n' "  Reports framework installation status, vendor engine availability,"
        printf '    %s\n' "  workspace discovery, and detected LLM CLIs."
        return 0
        ;;
      -*) die "Unknown option: $1. Valid: --help" ;;
      *) shift ;;
    esac
  done

  header "Pilosa — System Health"
  local issues=0

  if [[ -n "$FRAMEWORK_ROOT" ]]; then
    ok "Framework found: ${FRAMEWORK_ROOT}"
  else
    warn "Framework not found — is Pilosa installed?"
    issues=$((issues + 1))
  fi

  if gum_available; then
    ok "Gum available"
  else
    note "Gum not available — plain prompts will be used"
  fi

  if rapidocr_ocr_available; then
    ok "RapidOCR OCR available for scanned PDFs and images"
  else
    note "RapidOCR OCR not bundled — scanned PDFs and images will be skipped"
  fi

  if markitdown_available; then
    ok "MarkItDown available for Office docs, EPUB, HTML, and text-based PDFs"
  else
    note "MarkItDown not bundled — Office docs and text PDFs will be skipped"
  fi

  local ws_count
  spinner_start "Discovering workspaces"
  local workspace_data
  workspace_data="$(discover_workspaces_with_permission 2>/dev/null)"
  if [[ -n "$workspace_data" ]]; then
    ws_count="$(echo "$workspace_data" | wc -l | tr -d ' ')"
  else
    ws_count=0
  fi
  spinner_stop
  if [[ "$ws_count" -gt 0 ]]; then
    ok "${ws_count} workspace(s) discovered"
  else
    note "No workspaces discovered yet"
  fi

  local cli_count=0
  command -v claude >/dev/null 2>&1 && cli_count=$((cli_count + 1))
  command -v codex >/dev/null 2>&1 && cli_count=$((cli_count + 1))
  command -v opencode >/dev/null 2>&1 && cli_count=$((cli_count + 1))
  ok "${cli_count} LLM CLI(s) detected"

  divider
  if [[ "$issues" -gt 0 ]]; then
    warn "${issues} issue(s) found"
  else
    ok "System health check passed"
  fi
  echo ""
}



# Fetch release notes from GitHub API
fetch_release_notes() {
  local version="${1:-latest}"
  local api_url
  
  if [[ "$version" == "latest" ]]; then
    api_url="https://api.github.com/repos/TommasoPrinetti/pilosa/releases/latest"
  else
    api_url="https://api.github.com/repos/TommasoPrinetti/pilosa/releases/tags/v${version}"
  fi
  
  # Use Python for reliable JSON parsing
  local _py=python3
  command -v python3 >/dev/null 2>&1 || _py=python
  curl -fsSL "$api_url" 2>/dev/null | "$_py" -c "
import sys, json
try:
    data = json.load(sys.stdin)
    tag = data.get('tag_name', '')
    published = data.get('published_at', '').replace('T', ' ').replace('Z', '')
    body = data.get('body', '')
    print(f'{tag}|{published}|{body}')
except:
    pass
" 2>/dev/null
}

# Display release notes in a formatted way
display_release_notes() {
  local release_data="$1"
  local tag_name published_at body
  
  tag_name="$(echo "$release_data" | cut -d'|' -f1)"
  published_at="$(echo "$release_data" | cut -d'|' -f2)"
  body="$(echo "$release_data" | cut -d'|' -f3-)"

  # Extract key lines: strip markdown, code fences, commands, keep only descriptions
  local lines
  lines="$(echo "$body" | sed -E '
    /^```/d
    /^curl /d
    /^bash /d
    /^pilosa /d
    /^For options/d
    /^Pilosa Framework/d
    /^##+ (Install|Update)/d
    s/^This installs.*/↳ Zero dependencies, bundled OCR + MarkItDown/
    s/^- Framework-owned.*/↳ Framework files updated from release/
    s/^- User workspace.*/↳ Your workspace is preserved/
    s/^- Locally modified.*/↳ Modified files get .pilosa-new sidecars/
  ' | sed '/^$/d')"

  printf '\n'
  if [[ -n "$lines" ]]; then
    printf '  %s┌%s┐\n' "${DIM}" "$(printf '%.0s─' 1 {1..60})"
    printf '  %s│%s %s%s%s\n' "${DIM}" "${RESET}" "${BOLD}${tag_name}${RESET}" "${DIM}" "${RESET}"
    printf '  %s├%s┤\n' "${DIM}" "$(printf '%.0s─' 1 {1..60})"
    echo "$lines" | while IFS= read -r line; do
      printf '  %s│%s %s\n' "${DIM}" "${RESET}" "$line"
    done
    printf '  %s└%s┘\n' "${DIM}" "$(printf '%.0s─' 1 {1..60})"
  else
    note "${BOLD}${tag_name}${RESET}"
  fi
  echo ""
}

# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: upgrade
# ═══════════════════════════════════════════════════════════════════════════
cmd_upgrade() {
  local target_version="latest"
  local auto_yes=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --version) target_version="$2"; shift 2 ;;
      --yes|-y) auto_yes=1; shift ;;
      --help|-h)
        printf '  %s\n' "Usage: pilosa upgrade [options]"
        printf '    %s\n' "  --version X.Y.Z   Upgrade to specific version (default: latest)"
        printf '    %s\n' "  --yes             Skip confirmation prompt"
        printf '    %s\n' "  --help            Show this help"
        return 0
        ;;
      -*) die "Unknown upgrade option: $1. Valid: --version, --yes, --help" ;;
      *) shift ;;
    esac
  done

  header "Pilosa — Upgrade"

  # Fetch and display release notes before confirmation
  if [[ "$auto_yes" -ne 1 ]]; then
    spinner_start "Fetching release notes"
    local release_data
    release_data="$(fetch_release_notes "$target_version")"
    spinner_stop
    
    if [[ -n "$release_data" ]]; then
      display_release_notes "$release_data"
    else
      warn "Could not fetch release notes"
      printf '\n'
    fi
  fi

  # Confirm before downloading and running installer
  if [[ "$auto_yes" -ne 1 ]]; then
    if ! confirm "Download and run the Pilosa installer to upgrade?" "y"; then
      info "Upgrade cancelled."
      return 0
    fi
  fi

  info "Downloading latest installer..."

  local tmpdir
  tmpdir="$(mktemp -d)"
  local installer="${tmpdir}/install-pilosa.sh"

  # Resolve latest version from GitHub
  # PILOSA_REPO env var is intentionally NOT used here — self-upgrade
  # must always point to the canonical upstream to prevent supply-chain attacks
  # via compromised environment variables.
  spinner_start "Resolving latest version"
  local latest_version
  latest_version="$(curl -fsSL -o /dev/null -w '%{url_effective}' "https://github.com/TommasoPrinetti/pilosa/releases/latest" 2>/dev/null | sed 's|.*/tag/v||' || echo "")"
  spinner_stop
  
  if [[ -n "$latest_version" ]]; then
    spinner_start "Downloading installer v${latest_version}"
    if ! curl -fsSL "https://github.com/TommasoPrinetti/pilosa/releases/download/v${latest_version}/install.sh" -o "$installer" 2>/dev/null; then
      spinner_stop
      warn "Could not download release installer. Falling back to raw main branch..."
      spinner_start "Downloading from main branch"
      curl -fsSL "https://raw.githubusercontent.com/TommasoPrinetti/pilosa/main/install.sh" -o "$installer" || die "Could not download installer"
    fi
    spinner_stop
  else
    spinner_start "Downloading from main branch"
    curl -fsSL "https://raw.githubusercontent.com/TommasoPrinetti/pilosa/main/install.sh" -o "$installer" || die "Could not download installer"
    spinner_stop
  fi

  ok "Installer downloaded"

  local upgrade_args=("--upgrade")
  if [[ "$target_version" != "latest" ]]; then
    upgrade_args+=("--version" "$target_version")
  fi
  if [[ "$auto_yes" -eq 1 ]]; then
    upgrade_args+=("--yes")
  fi

  bash "$installer" "${upgrade_args[@]}"

  rm -rf "$tmpdir"
}

# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: dashboard
# ═══════════════════════════════════════════════════════════════════════════
cmd_dashboard() {
  local version
  version="$(framework_version "$FRAMEWORK_ROOT")"
  [[ -z "$version" || "$version" == "dev" ]] && version="dev"
  local in_workspace=0
  local project_name="" setup_status="" fw_version=""
  local discovered_workspaces=()
  local cli_labels=()

  header "Pilosa — Research Framework"
  printf '  %s v%s%s\n\n' "${BOLD}" "$version" "${RESET}"

  # ── Workspace context ─────────────────────────────────────────────────
  if [[ -f ".pilosa/workspace" ]]; then
    in_workspace=1
    project_name="$(grep 'project_name:' .pilosa/workspace 2>/dev/null | sed 's/project_name: *//' | head -1)"
    setup_status="$(grep 'setup_status:' .pilosa/workspace 2>/dev/null | sed 's/setup_status: *//' | head -1)"
    fw_version="$(grep 'framework_version:' .pilosa/workspace 2>/dev/null | sed 's/framework_version: *//' | head -1)"
  fi

  if [[ "$in_workspace" -eq 1 ]]; then
    printf '  %sWorkspace:%s %s\n' "${BOLD}" "${RESET}" "${project_name:-unknown}"
    printf '  %sStatus:%s    %s\n' "${BOLD}" "${RESET}" "${setup_status:-unknown}"
    printf '  %sFramework:%s v%s\n' "${BOLD}" "${RESET}" "${fw_version:-unknown}"
  else
    # Discover workspaces with permission and caching
    # First check if we need permission (without spinner)
    load_config
    if [[ "$SCAN_PERMISSION" == "unknown" ]]; then
      # Need to ask permission - do it without spinner
      if ! ask_scan_permission; then
        info "Workspace discovery denied. You can manually specify workspace paths."
      else
        load_config  # Reload after saving
      fi
    fi
    
    # Now discover workspaces with spinner
    if [[ "$SCAN_PERMISSION" == "granted" ]]; then
      spinner_start "Discovering workspaces"
      local workspace_data
      workspace_data="$(discover_workspaces_with_permission 2>/dev/null)"
      spinner_stop
    else
      local workspace_data=""
    fi
    
    if [[ -n "$workspace_data" ]]; then
      while IFS='|' read -r ws_path project; do
        [[ -n "$ws_path" ]] && discovered_workspaces+=("$ws_path|$project")
      done <<< "$workspace_data"
    fi

    if [[ ${#discovered_workspaces[@]} -gt 0 ]]; then
      printf '  %sDiscovered workspaces:%s %d\n' "${BOLD}" "${RESET}" "${#discovered_workspaces[@]}"
      local i entry ws_path project ws_name
      for i in "${!discovered_workspaces[@]}"; do
        entry="${discovered_workspaces[$i]}"
        ws_path="${entry%%|*}"
        project="${entry#*|}"
        ws_name="$(basename "$ws_path")"
        if [[ $i -lt 3 ]]; then
          if [[ -n "$project" ]]; then
            printf '    %s %s %s(%s)%s\n' "${DIM}•${RESET}" "$ws_name" "${DIM}" "$project" "${RESET}"
          else
            printf '    %s %s\n' "${DIM}•${RESET}" "$ws_name"
          fi
        fi
      done
      if [[ ${#discovered_workspaces[@]} -gt 3 ]]; then
        printf '    %s ... and %d more\n' "${DIM}" "$((${#discovered_workspaces[@]} - 3))"
      fi
    else
      printf '  %sNo workspaces yet — start with New workspace%s\n' "${DIM}" "${RESET}"
    fi
  fi

  printf '\n'

  # ── LLM CLIs ──────────────────────────────────────────────────────────
  spinner_start "Detecting LLM CLIs"
  local cli_output
  cli_output="$(detect_llm_clis)"
  spinner_stop
  if [[ -n "$cli_output" ]]; then
    while IFS= read -r line; do
      [[ -n "$line" ]] && cli_labels+=("$line")
    done <<< "$cli_output"
  fi

  if [[ ${#cli_labels[@]} -gt 0 ]]; then
    printf '  %sLLM CLIs:%s ' "${BOLD}" "${RESET}"
    local i
    for i in "${!cli_labels[@]}"; do
      if [[ $i -gt 0 ]]; then
        printf ', '
      fi
      printf '%s %s' "${G}✓${RESET}" "${cli_labels[$i]}"
    done
    printf '\n'
  fi

  printf '\n'
  divider
  printf '\n'

  # ── Menu ──────────────────────────────────────────────────────────────
  while true; do
    local options=()
    options+=("$(option_spec "new" "New workspace" "Create a new workspace and run onboarding")")
    options+=("$(option_spec "onboard" "Onboard workspace" "Run onboarding on an existing workspace")")
    options+=("$(option_spec "update" "Update workspace" "Update workspace framework files")")
    options+=("$(option_spec "check" "Check workspace" "Validate workspace integrity")")
    options+=("$(option_spec "sync" "Sync agents" "Sync agent and skill mirrors")")
    options+=("$(option_spec "upgrade" "Upgrade Pilosa" "Upgrade to latest release")")
    options+=("$(option_spec "health" "System health" "Check system health and environment")")
    options+=("$(option_spec "uninstall" "Uninstall" "Remove Pilosa from this system")")
    options+=("$(option_spec "help" "Help" "Show help information")")
    options+=("$(option_spec "quit" "Quit" "Exit Pilosa")")

    local choice
    choice="$(prompt_choose "What would you like to do?" "${options[@]}")" || return 0

    printf '\n'

    case "$choice" in
      new)       cmd_new "$@" ;;
      onboard)   cmd_onboard "$@" ;;
      update)    cmd_update "$@" ;;
      check)     cmd_check "$@" ;;
      sync)      cmd_sync "$@" ;;
      upgrade)   cmd_upgrade "$@" ;;
      health)    cmd_health "$@" ;;
      uninstall) cmd_uninstall "$@" ;;
      help)      cmd_help ;;
      quit)      return 0 ;;
      *)         return 0 ;;
    esac

    printf '\n'
  done
}

# ═══════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════
case "${1:-}" in
  new)       shift; cmd_new "$@" ;;
  onboard)   shift; cmd_onboard "$@" ;;
  update)    shift; cmd_update "$@" ;;
  upgrade)   shift; cmd_upgrade "$@" ;;
  check)     shift; cmd_check "$@" ;;
  sync)      shift; cmd_sync "$@" ;;
  health)    shift; cmd_health "$@" ;;
  uninstall) shift; cmd_uninstall "$@" ;;
  help|-h|--help) cmd_help ;;
  --version|-v) printf 'pilosa %s\n' "$(framework_version "$FRAMEWORK_ROOT")"; exit 0 ;;
  "") cmd_dashboard ;;
  *)
    printf '%s\n' "${R}Unknown command: $1${RESET}" >&2
    cmd_help
    exit 1
    ;;
esac


