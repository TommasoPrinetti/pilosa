#!/usr/bin/env bash
set -euo pipefail

# ── pilosa — CLI entry point ────────────────────────────────────────────────
# Usage: pilosa [new|onboard|update|check|sync|uninstall|help]
#
# Commands:
#   new       Create a new Pilosa workspace and run onboarding
#   onboard   Run onboarding on an existing workspace
#   update    Update workspace framework files from a release
#   check     Validate workspace integrity and configuration
#   sync      Sync agent and skill mirrors from canonical sources
#   uninstall Remove Pilosa from this system
#   help      Show this help

# ── ANSI colors (zero dependencies) ─────────────────────────────────────────
if [[ "${NO_COLOR:-}" == "1" ]] || [[ ! -t 1 ]]; then
  R="" G="" B="" Y="" C="" M="" DIM="" BOLD="" RESET=""
else
  R=$'\033[31m' G=$'\033[32m' B=$'\033[34m' Y=$'\033[33m'
  C=$'\033[36m' M=$'\033[35m' DIM=$'\033[2m' BOLD=$'\033[1m' RESET=$'\033[0m'
fi

# ── paths ───────────────────────────────────────────────────────────────────
PILOSA_HOME="${PILOSA_HOME:-$HOME/.pilosa}"
PILOSA_REPO="${PILOSA_REPO:-TommasoPrinetti/pilosa}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TODAY="$(date +%Y-%m-%d)"
USE_GUM="${USE_GUM:-1}"

# Source file classes used by integrated onboarding.
MARKDOWN_EXTENSIONS="txt|rtf|textile|wiki|mediawiki|dokuwiki|pmwiki|outliner|workflowy|dynalist"
NATIVE_EXTENSIONS="md|csv|json|yaml|yml|toml|xml|html|css|js|ts|py|rb|sh|log|ini|cfg|conf|tex|bib|org|adoc|rst|tiddlywiki|logseq|roam|obsidian"
BINARY_COPYABLE_EXTENSIONS="pdf"
PDF_CONVERTIBLE_EXTENSIONS="pdf"

# Resolve framework root:
#   - Dev mode: binary is in .bin/ of the repo → FRAMEWORK_ROOT is repo root
#   - Installed mode: binary is in ~/.pilosa/bin/ → framework is in ~/.pilosa/versions/<latest>/
resolve_framework_root() {
  # Dev mode: check if we're in the repo's .bin/
  local candidate="${SCRIPT_DIR}/.."
  if [[ -f "${candidate}/.pilosa/framework-files.tsv" ]]; then
    echo "$candidate"
    return
  fi

  # Installed mode: find latest version
  if [[ -d "${PILOSA_HOME}/versions" ]]; then
      local latest_version
      local portable_sort
      if sort -V /dev/null 2>/dev/null; then
        portable_sort="sort -V"
      else
        portable_sort="sort -t. -k1,1n -k2,2n -k3,3n"
      fi
      latest_version="$(ls -1 "${PILOSA_HOME}/versions" 2>/dev/null | $portable_sort | tail -1)"
    if [[ -n "$latest_version" ]]; then
      local fw_dir="${PILOSA_HOME}/versions/${latest_version}"
      # The archive unpacks to pilosa-framework-<version>/
      local fw_subdir
      fw_subdir="$(find "$fw_dir" -maxdepth 1 -type d -name 'pilosa-framework-*' 2>/dev/null | head -1)"
      if [[ -n "$fw_subdir" && -f "${fw_subdir}/.pilosa/framework-files.tsv" ]]; then
        echo "$fw_subdir"
        return
      fi
    fi
  fi

  echo ""
}

FRAMEWORK_ROOT="$(resolve_framework_root)"

# ── helpers ─────────────────────────────────────────────────────────────────
divider()   { printf '%s\n' "${DIM}$(printf '%.0s─' 1 {1..78})${RESET}"; }
header()    { printf '\n%s\n\n' "${BOLD}${C}$1${RESET}"; }
info()      { printf '  %s %s\n' "${DIM}→${RESET}" "$1"; }
ok()        { printf '  %s %s\n' "${G}✦${RESET}" "$1"; }
warn()      { printf '  %s %s\n' "${Y}⚠${RESET}" "$1"; }
note()      { printf '  %s↳%s %s\n' "${DIM}" "${RESET}" "$1"; }
die()       { printf '\n  %s %s\n\n' "${R}✗${RESET}" "$1" >&2; exit 1; }
print_step(){ printf '\n  %s%s[%s/%s] %s%s\n' "${BOLD}" "${C}" "$1" "$2" "$3" "${RESET}"; }

gum_available() {
  [[ "$USE_GUM" == "1" && -t 0 ]] || return 1
  [[ -x "${PILOSA_HOME}/bin/gum" ]] && return 0
  command -v gum >/dev/null 2>&1
}

gum_bin() {
  if [[ -x "${PILOSA_HOME}/bin/gum" ]]; then
    echo "${PILOSA_HOME}/bin/gum"
  else
    command -v gum 2>/dev/null
  fi
}

gum_input() {
  local prompt="$1" value="${2:-}" bin
  bin="$(gum_bin)" || return 127
  "$bin" input --placeholder "$prompt" --value "$value"
}

gum_file() {
  local title="$1" bin
  bin="$(gum_bin)" || return 127
  "$bin" file --directory --title "$title"
}

gum_choose() {
  local prompt="$1" bin
  shift
  bin="$(gum_bin)" || return 127
  "$bin" choose --header "$prompt" "$@"
}

gum_confirm() {
  local prompt="$1" bin
  bin="$(gum_bin)" || return 127
  "$bin" confirm "$prompt"
}

ask() {
  local prompt="$1" default="${2:-}" hint="${3:-}"
  local fb=""
  [[ -n "$default" ]] && fb=" ${DIM}(${default})${RESET}"
  [[ -n "$hint" ]] && printf '  %s %s\n' "${DIM}↳${RESET}" "$hint" >&2
  printf '%s' "${BOLD}${prompt}${RESET}${fb}${DIM}: ${RESET}" >&2
  local reply
  IFS= read -r reply || true
  reply="${reply:-$default}"
  echo "$reply"
}

confirm() {
  local prompt="$1" default="${2:-y}"
  local hint="Y/n"
  [[ "$default" == "n" ]] && hint="y/N"
  local reply normalized
  while true; do
    printf '%s' "${BOLD}${prompt}${RESET} ${DIM}${hint}${RESET}: " >&2
    IFS= read -r reply || reply="$default"
    reply="${reply:-$default}"
    normalized="$(printf '%s' "$reply" | tr '[:upper:]' '[:lower:]')"
    case "$normalized" in
      y|yes) return 0 ;;
      n|no) return 1 ;;
      *) printf '  %s\n' "${R}Please answer y/yes or n/no.${RESET}" >&2 ;;
    esac
  done
}

select_menu() {
  local prompt="$1"
  shift
  local options=("$@")

  printf '%s\n' "${BOLD}${prompt}${RESET}" >&2
  for i in "${!options[@]}"; do
    printf '  %s %s\n' "${DIM}$((i+1)).${RESET}" "${options[$i]}" >&2
  done

  local choice
  while true; do
    printf '%s' "${DIM}  Enter number [1-${#options[@]}]: ${RESET}" >&2
    IFS= read -r choice || choice="1"
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#options[@]} )); then
      echo "${options[$((choice-1))]}"
      return
    fi
    printf '  %s\n' "${R}Invalid choice. Try again.${RESET}" >&2
  done
}

arrow_select() {
  local prompt="$1"
  shift
  local options=("$@")

  if [[ "${NUMBERED:-0}" == "1" ]] || [[ ! -t 0 ]]; then
    select_menu "$prompt" "${options[@]}"
    return
  fi

  if ! command -v stty >/dev/null 2>&1; then
    select_menu "$prompt" "${options[@]}"
    return
  fi

  local count=${#options[@]}
  local current=0
  local key seq part
  local old_stty
  old_stty=$(stty -g 2>/dev/null) || { select_menu "$prompt" "${options[@]}"; return; }

  printf '\n  %s\n' "${BOLD}${prompt}${RESET}" >&2
  printf '  %s\n' "${DIM}↑/↓ to move, Enter to confirm, q to cancel${RESET}" >&2
  for i in "${!options[@]}"; do
    if (( i == current )); then
      printf '  %s %s %s\n' "${C}" "▶" "${BOLD}${options[$i]}${RESET}" >&2
    else
      printf '    %s\n' "${options[$i]}" >&2
    fi
  done

  if ! stty raw -echo 2>/dev/null; then
    printf '\n  %s arrow-key mode failed, falling back to numbered menu\n' "${Y}⚠${RESET}" >&2
    printf '\033[%dF' "$count" >&2
    for _ in "${!options[@]}"; do printf '\r\033[2K\n' >&2; done
    select_menu "$prompt" "${options[@]}"
    return
  fi

  local old_int_trap old_term_trap old_exit_trap
  old_int_trap="$(trap -p INT || true)"
  old_term_trap="$(trap -p TERM || true)"
  old_exit_trap="$(trap -p EXIT || true)"

  restore_arrow_traps() {
    if [[ -n "$old_int_trap" ]]; then eval "$old_int_trap"; else trap - INT; fi
    if [[ -n "$old_term_trap" ]]; then eval "$old_term_trap"; else trap - TERM; fi
    if [[ -n "$old_exit_trap" ]]; then eval "$old_exit_trap"; else trap - EXIT; fi
  }

  cleanup_arrow() {
    stty "$old_stty" 2>/dev/null || true
    printf '\033[?25h' >&2
    restore_arrow_traps
  }
  trap 'cleanup_arrow; printf "\n  Cancelled.\n" >&2; exit 1' INT TERM
  trap 'cleanup_arrow' EXIT

  while true; do
    IFS= read -r -n 1 -s key 2>/dev/null || { cleanup_arrow; return 1; }
    case "$key" in
      $'\x1b')
        seq=""
        while IFS= read -r -n 1 -s -t 1 part 2>/dev/null; do
          seq+="$part"
          [[ ${#seq} -ge 2 ]] && break
        done
        case "$seq" in
          '[A'|'OA') ((current--)); ((current < 0)) && current=$((count - 1)) ;;
          '[B'|'OB') ((current++)); ((current >= count)) && current=0 ;;
          *) continue ;;
        esac
        printf '\033[%dF' "$count" >&2
        for _ in "${!options[@]}"; do printf '\r\033[2K\n' >&2; done
        for i in "${!options[@]}"; do
          if (( i == current )); then
            printf '  %s %s %s\n' "${C}" "▶" "${BOLD}${options[$i]}${RESET}" >&2
          else
            printf '    %s\n' "${options[$i]}" >&2
          fi
        done
        ;;
      '')
        cleanup_arrow
        echo "${options[$current]}"
        return
        ;;
      q|Q)
        cleanup_arrow
        printf '\n  Cancelled.\n' >&2
        return 1
        ;;
    esac
  done
}

normalize_path_input() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  if [[ ${#value} -ge 2 ]]; then
    if [[ "${value:0:1}" == "'" && "${value: -1}" == "'" ]] || [[ "${value:0:1}" == '"' && "${value: -1}" == '"' ]]; then
      value="${value:1:${#value}-2}"
    fi
  fi
  value="${value//\\ / }"
  echo "$value"
}

expand_home() {
  local path="$1"
  if [[ "$path" == "~"* ]]; then
    path="${path/#\~/$HOME}"
  fi
  echo "$path"
}

# ── Gum integration (optional, private install) ─────────────────────────────
pilosa_gum() {
  if [ -x "${PILOSA_HOME}/bin/gum" ]; then
    "${PILOSA_HOME}/bin/gum" "$@"
  else
    return 127
  fi
}

# ── checksum helper ─────────────────────────────────────────────────────────
sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    return 1
  fi
}

download_file() {
  local url="$1" dest="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$dest"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$url" -O "$dest"
  else
    die "Neither curl nor wget found. Please install one."
  fi
}

verify_checksum() {
  local file="$1" expected="$2"
  local actual
  actual="$(sha256_file "$file" 2>/dev/null || true)"
  [[ -n "$actual" ]] || die "No SHA-256 tool found. Cannot verify release artifact."
  [[ "$actual" == "$expected" ]] || die "Checksum mismatch for $(basename "$file")"
}

manifest_hash() {
  local manifest="$1" path="$2"
  awk -F '\t' -v p="$path" '$1 == p { print $2; exit }' "$manifest"
}

framework_version() {
  local root="$1"
  if [[ -f "${root}/metadata/version" ]]; then
    sed -n '1p' "${root}/metadata/version"
  else
    echo "dev"
  fi
}

is_release_managed_role() {
  local role="$1"
  [[ "$role" != "user_state" && "$role" != "generated_state" ]]
}

next_sidecar_path() {
  local dst="$1"
  local sidecar="${dst}.pilosa-new"
  local n=1
  while [[ -e "$sidecar" ]]; do
    sidecar="${dst}.pilosa-new.${n}"
    n=$((n + 1))
  done
  echo "$sidecar"
}

resolve_latest_release_version() {
  local url
  if ! command -v curl >/dev/null 2>&1; then
    die "curl is required to resolve latest. Use --version X.Y.Z instead."
  fi
  url="$(curl -fsSL -o /dev/null -w '%{url_effective}' "https://github.com/${PILOSA_REPO}/releases/latest" 2>/dev/null || true)"
  [[ -n "$url" && "$url" != */latest ]] || die "Could not resolve latest version. Use --version X.Y.Z instead."
  basename "$url" | sed 's/^v//'
}

release_dir_version() {
  local release_dir="$1" version="$2"
  if [[ "$version" != "latest" ]]; then
    echo "$version"
    return
  fi
  basename "$release_dir" | sed 's/^v//'
}

prepare_release_framework() {
  local requested_version="$1" release_dir="$2" tmpdir="$3"
  local version archive_name archive_path checksums_path expected framework_dir

  if [[ -n "$release_dir" ]]; then
    version="$(release_dir_version "$release_dir" "$requested_version")"
  elif [[ "$requested_version" == "latest" ]]; then
    version="$(resolve_latest_release_version)"
  else
    version="$requested_version"
  fi

  archive_name="pilosa-framework-${version}.tar.gz"
  archive_path="${tmpdir}/${archive_name}"
  checksums_path="${tmpdir}/checksums.txt"

  if [[ -n "$release_dir" ]]; then
    [[ -f "${release_dir}/${archive_name}" ]] || die "Release archive not found: ${release_dir}/${archive_name}"
    [[ -f "${release_dir}/checksums.txt" ]] || die "Release checksums not found: ${release_dir}/checksums.txt"
    cp "${release_dir}/${archive_name}" "$archive_path"
    cp "${release_dir}/checksums.txt" "$checksums_path"
  else
    local base_url="${PILOSA_RELEASE_BASE_URL:-https://github.com/${PILOSA_REPO}/releases/download/v${version}}"
    info "Downloading release: v${version}" >&2
    download_file "${base_url}/${archive_name}" "$archive_path"
    download_file "${base_url}/checksums.txt" "$checksums_path"
  fi

  expected="$(awk -v f="$archive_name" '$2 == f { print $1; exit }' "$checksums_path")"
  [[ -n "$expected" ]] || die "${archive_name} not found in checksums.txt"
  verify_checksum "$archive_path" "$expected"

  tar -xzf "$archive_path" -C "$tmpdir"
  framework_dir="${tmpdir}/pilosa-framework-${version}"
  [[ -f "${framework_dir}/.pilosa/framework-files.tsv" ]] || die "Release manifest missing from archive"
  printf '%s\t%s\n' "$version" "$framework_dir"
}

copy_to_clipboard() {
  local text="$1"
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$text" | pbcopy
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$text" | xclip -selection clipboard
  elif command -v xsel >/dev/null 2>&1; then
    printf '%s' "$text" | xsel --clipboard --input
  elif command -v clip.exe >/dev/null 2>&1; then
    printf '%s' "$text" | clip.exe
  else
    return 1
  fi
}

sanitize_yaml() { printf '%s' "$1" | tr '"' "'" | tr '\n' ' '; }

shell_quote() {
  local value="$1"
  value="${value//\'/\'\\\'\'}"
  printf "'%s'" "$value"
}

prompt_preview() {
  local line count=0
  while IFS= read -r line; do
    printf '%s\n' "$line"
    count=$((count + 1))
    [[ "$count" -ge 4 ]] && break
  done
  printf '...\n'
}

print_box() {
  printf '\n  %s┌%s┐%s\n' "${DIM}" "$(printf '%.0s─' 1 {1..76})" "${RESET}"
  printf '  %s│%s %s%s%s\n' "${DIM}" "${RESET}" "${BOLD}$1${RESET}" "${DIM}" "${RESET}"
  printf '  %s├%s┤%s\n' "${DIM}" "$(printf '%.0s─' 1 {1..76})" "${RESET}"
  while IFS= read -r line; do
    printf '  %s│%s %s\n' "${DIM}" "${RESET}" "$line"
  done
  printf '  %s└%s┘%s\n' "${DIM}" "$(printf '%.0s─' 1 {1..76})" "${RESET}"
}

build_launch_command() {
  local root="$1" cli="$2" prompt="$3" root_cmd
  root_cmd="$(shell_quote "$root")"

  case "$cli" in
    "Codex")
      printf 'codex -C %s "$(cat <<'\''PILOSA_STARTUP_PROMPT'\''\n' "$root_cmd"
      printf '%s\n' "$prompt"
      printf 'PILOSA_STARTUP_PROMPT\n)"\n'
      ;;
    "Codex App")
      printf 'codex app %s\n' "$root_cmd"
      ;;
    "OpenCode")
      printf 'opencode --prompt "$(cat <<'\''PILOSA_STARTUP_PROMPT'\''\n'
      printf '%s\n' "$prompt"
      printf 'PILOSA_STARTUP_PROMPT\n)" %s\n' "$root_cmd"
      ;;
    "OpenCode Desktop")
      printf 'opencode %s\n' "$root_cmd"
      ;;
    "Claude Code")
      printf 'cd %s && claude "$(cat <<'\''PILOSA_STARTUP_PROMPT'\''\n' "$root_cmd"
      printf '%s\n' "$prompt"
      printf 'PILOSA_STARTUP_PROMPT\n)"\n'
      ;;
    "Claude Code Desktop")
      local encoded_prompt
      encoded_prompt="$(printf '%s' "$prompt" | python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.stdin.read(), safe=""))' 2>/dev/null || printf '%s' "$prompt" | sed 's/ /%20/g; s/"/%22/g')"
      printf 'open "claude://code/new?q=%s&folder=%s"\n' "$encoded_prompt" "$root_cmd"
      ;;
    "Kilo")
      printf 'cd %s && kilo "$(cat <<'\''PILOSA_STARTUP_PROMPT'\''\n' "$root_cmd"
      printf '%s\n' "$prompt"
      printf 'PILOSA_STARTUP_PROMPT\n)"\n'
      ;;
    *)
      printf 'cd %s && <your-llm-cli> "$(cat <<'\''PILOSA_STARTUP_PROMPT'\''\n' "$root_cmd"
      printf '%s\n' "$prompt"
      printf 'PILOSA_STARTUP_PROMPT\n)"\n'
      ;;
  esac
}

run_cli_with_prompt() {
  local root="$1" cli="$2" prompt="$3"
  case "$cli" in
    "Codex")
      command -v codex >/dev/null 2>&1 || { warn "codex was not found on PATH."; return 1; }
      exec codex -C "$root" "$prompt"
      ;;
    "Codex App")
      command -v codex >/dev/null 2>&1 || { warn "codex was not found on PATH."; return 1; }
      copy_to_clipboard "$prompt"
      codex app "$root" &
      ok "Prompt copied to clipboard — paste it in the Codex app."
      ;;
    "OpenCode")
      command -v opencode >/dev/null 2>&1 || { warn "opencode was not found on PATH."; return 1; }
      exec opencode --prompt "$prompt" "$root"
      ;;
    "OpenCode Desktop")
      command -v opencode >/dev/null 2>&1 || { warn "opencode was not found on PATH."; return 1; }
      copy_to_clipboard "$prompt"
      opencode "$root" &
      ok "Prompt copied to clipboard — paste it in the OpenCode TUI."
      ;;
    "Claude Code")
      command -v claude >/dev/null 2>&1 || { warn "claude was not found on PATH."; return 1; }
      cd "$root"
      exec claude "$prompt"
      ;;
    "Claude Code Desktop")
      local encoded_prompt
      encoded_prompt="$(printf '%s' "$prompt" | python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.stdin.read(), safe=""))' 2>/dev/null || printf '%s' "$prompt" | sed 's/ /%20/g; s/"/%22/g')"
      if [[ "$(uname)" == "Darwin" ]]; then
        open "claude://code/new?q=${encoded_prompt}&folder=${root}"
        ok "Opening Claude Code Desktop with pre-filled prompt."
      else
        copy_to_clipboard "$prompt"
        ok "Prompt copied to clipboard — open Claude Code Desktop and paste it."
      fi
      ;;
    "Kilo")
      command -v kilo >/dev/null 2>&1 || { warn "kilo was not found on PATH."; return 1; }
      cd "$root"
      exec kilo "$prompt"
      ;;
    *)
      warn "Run-now is only available for known CLI choices."
      return 1
      ;;
  esac
}

should_skip_source_file() {
  local name lower_name
  name="$(basename "$1")"
  lower_name="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
  [[ "$lower_name" == "agents.md" ]] && return 0
  case "$1" in
    */.DS_Store|*/.gitkeep|*/node_modules/*|*/.git/*) return 0 ;;
    *) return 1 ;;
  esac
}

file_ext() {
  local name ext
  name="$(basename "$1")"
  [[ "$name" == *.* ]] || { echo ""; return; }
  ext="${name##*.}"
  printf '%s' "$ext" | tr '[:upper:]' '[:lower:]'
}

ext_in_list() {
  local ext="$1" list="$2"
  case "|$list|" in
    *"|$ext|"*) return 0 ;;
    *) return 1 ;;
  esac
}

is_markdown_convertible_file() { local ext; ext="$(file_ext "$1")"; [[ -n "$ext" ]] && ext_in_list "$ext" "$MARKDOWN_EXTENSIONS"; }
is_native_readable_file() { local ext; ext="$(file_ext "$1")"; [[ -n "$ext" ]] && ext_in_list "$ext" "$NATIVE_EXTENSIONS"; }
is_binary_copyable_file() { local ext; ext="$(file_ext "$1")"; [[ -n "$ext" ]] && ext_in_list "$ext" "$BINARY_COPYABLE_EXTENSIONS"; }
is_pdf_convertible_file() { local ext; ext="$(file_ext "$1")"; [[ -n "$ext" ]] && ext_in_list "$ext" "$PDF_CONVERTIBLE_EXTENSIONS"; }

pdf_converter_available() {
  [[ -x "${PILOSA_HOME}/bin/pdf2md" ]] && return 0
  command -v pdf2md >/dev/null 2>&1
}

pdf2md_bin() {
  if [[ -x "${PILOSA_HOME}/bin/pdf2md" ]]; then
    echo "${PILOSA_HOME}/bin/pdf2md"
  else
    command -v pdf2md 2>/dev/null
  fi
}

markdown_raw_rel_path() {
  local rel_path="$1" name dir stem ext
  name="$(basename "$rel_path")"
  dir="$(dirname "$rel_path")"
  ext="$(file_ext "$rel_path")"
  [[ "$ext" == "md" ]] && { echo "$rel_path"; return; }
  stem="${name%.*}"
  if [[ "$dir" == "." ]]; then
    echo "${stem}__${ext}.md"
  else
    echo "${dir}/${stem}__${ext}.md"
  fi
}

truncate_display_path() {
  local value="$1" max_len="$2"
  if (( ${#value} <= max_len )); then
    echo "$value"
  else
    echo "...${value:$((${#value} - max_len + 3))}"
  fi
}

plural_count() {
  local count="$1" singular="$2" plural="${3:-$2s}"
  if [[ "$count" -eq 1 ]]; then
    printf '1 %s' "$singular"
  else
    printf '%d %s' "$count" "$plural"
  fi
}

file_size_bytes() {
  local path="$1"
  if stat -c %s "$path" >/dev/null 2>&1; then
    stat -c %s "$path"
  elif stat -f %z "$path" >/dev/null 2>&1; then
    stat -f %z "$path"
  else
    printf '0'
  fi
}

format_bytes() {
  local bytes="$1"
  if [[ "$bytes" -ge 1073741824 ]]; then
    printf '%d.%02d GB' $((bytes / 1073741824)) $(((bytes % 1073741824) * 100 / 1073741824))
  elif [[ "$bytes" -ge 1048576 ]]; then
    printf '%d.%02d MB' $((bytes / 1048576)) $(((bytes % 1048576) * 100 / 1048576))
  elif [[ "$bytes" -ge 1024 ]]; then
    printf '%d.%02d KB' $((bytes / 1024)) $(((bytes % 1024) * 100 / 1024))
  else
    printf '%d B' "$bytes"
  fi
}

classify_source_file() {
  local path="$1" ext
  should_skip_source_file "$path" && { echo "ignored"; return; }
  is_markdown_convertible_file "$path" && { echo "markdown"; return; }
  is_native_readable_file "$path" && { echo "native"; return; }
  if is_pdf_convertible_file "$path"; then
    if pdf_converter_available; then
      echo "pdf_convertible"
    else
      echo "binary_copyable"
    fi
    return
  fi
  ext="$(file_ext "$path")"
  case "$ext" in
    jpg|jpeg|png|gif|webp|heic|heif|tif|tiff|bmp|svg) echo "image" ;;
    mp4|mov|m4v|avi|mkv|webm|wmv) echo "video" ;;
    mp3|wav|m4a|aac|flac|ogg|opus|aiff) echo "audio" ;;
    *) echo "unknown" ;;
  esac
}

scan_source() {
  local source_path="$1" f class size
  SCAN_TOTAL_COUNT=0
  SCAN_MARKDOWN_COUNT=0
  SCAN_NATIVE_COUNT=0
  SCAN_BINARY_COPYABLE_COUNT=0
  SCAN_PDF_CONVERTIBLE_COUNT=0
  SCAN_IMAGE_COUNT=0
  SCAN_VIDEO_COUNT=0
  SCAN_AUDIO_COUNT=0
  SCAN_UNKNOWN_COUNT=0
  SCAN_IGNORED_COUNT=0
  SCAN_MARKDOWN_BYTES=0
  SCAN_NATIVE_BYTES=0
  SCAN_BINARY_COPYABLE_BYTES=0
  SCAN_PDF_CONVERTIBLE_BYTES=0
  SCAN_IMAGE_BYTES=0
  SCAN_VIDEO_BYTES=0
  SCAN_AUDIO_BYTES=0
  SCAN_UNKNOWN_BYTES=0

  printf '\n'
  while IFS= read -r -d '' f; do
    class="$(classify_source_file "$f")"
    if [[ "$class" != "ignored" ]]; then
      SCAN_TOTAL_COUNT=$((SCAN_TOTAL_COUNT + 1))
      size="$(file_size_bytes "$f")"
      printf '\r\033[2K  %sscanning%s %s' "${DIM}" "${RESET}" "$(truncate_display_path "$f" 54)" >&2
    else
      size=0
    fi
    case "$class" in
      markdown) SCAN_MARKDOWN_COUNT=$((SCAN_MARKDOWN_COUNT + 1)); SCAN_MARKDOWN_BYTES=$((SCAN_MARKDOWN_BYTES + size)) ;;
      native) SCAN_NATIVE_COUNT=$((SCAN_NATIVE_COUNT + 1)); SCAN_NATIVE_BYTES=$((SCAN_NATIVE_BYTES + size)) ;;
      binary_copyable) SCAN_BINARY_COPYABLE_COUNT=$((SCAN_BINARY_COPYABLE_COUNT + 1)); SCAN_BINARY_COPYABLE_BYTES=$((SCAN_BINARY_COPYABLE_BYTES + size)) ;;
      pdf_convertible) SCAN_PDF_CONVERTIBLE_COUNT=$((SCAN_PDF_CONVERTIBLE_COUNT + 1)); SCAN_PDF_CONVERTIBLE_BYTES=$((SCAN_PDF_CONVERTIBLE_BYTES + size)) ;; 
      image) SCAN_IMAGE_COUNT=$((SCAN_IMAGE_COUNT + 1)); SCAN_IMAGE_BYTES=$((SCAN_IMAGE_BYTES + size)) ;;
      video) SCAN_VIDEO_COUNT=$((SCAN_VIDEO_COUNT + 1)); SCAN_VIDEO_BYTES=$((SCAN_VIDEO_BYTES + size)) ;;
      audio) SCAN_AUDIO_COUNT=$((SCAN_AUDIO_COUNT + 1)); SCAN_AUDIO_BYTES=$((SCAN_AUDIO_BYTES + size)) ;;
      unknown) SCAN_UNKNOWN_COUNT=$((SCAN_UNKNOWN_COUNT + 1)); SCAN_UNKNOWN_BYTES=$((SCAN_UNKNOWN_BYTES + size)) ;;
      ignored) SCAN_IGNORED_COUNT=$((SCAN_IGNORED_COUNT + 1)) ;;
    esac
  done < <(find "$source_path" -type f -print0 2>/dev/null)
  printf '\r\033[2K' >&2
}

print_scan_summary() {
  printf '  %s✓%s Source scan complete\n' "${G}" "${RESET}"
  [[ "$SCAN_MARKDOWN_COUNT" -gt 0 ]] && printf '  %s├─%s %s to rename to .md (%s)\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_MARKDOWN_COUNT" "text-based file")" "$(format_bytes "$SCAN_MARKDOWN_BYTES")"
  [[ "$SCAN_NATIVE_COUNT" -gt 0 ]] && printf '  %s├─%s %s to copy unchanged (%s)\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_NATIVE_COUNT" "native-readable file")" "$(format_bytes "$SCAN_NATIVE_BYTES")"
  if [[ "$SCAN_PDF_CONVERTIBLE_COUNT" -gt 0 ]]; then
    printf '  %s├─%s %s to convert to Markdown (%s)\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_PDF_CONVERTIBLE_COUNT" "PDF")" "$(format_bytes "$SCAN_PDF_CONVERTIBLE_BYTES")"
  fi
  [[ "$SCAN_BINARY_COPYABLE_COUNT" -gt 0 ]] && printf '  %s├─%s %s to copy as-is (%s)\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_BINARY_COPYABLE_COUNT" "PDF")" "$(format_bytes "$SCAN_BINARY_COPYABLE_BYTES")"
  [[ "$SCAN_IMAGE_COUNT" -gt 0 ]] && printf '  %s├─%s %s skipped (%s)\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_IMAGE_COUNT" "image")" "$(format_bytes "$SCAN_IMAGE_BYTES")"
  [[ "$SCAN_VIDEO_COUNT" -gt 0 ]] && printf '  %s├─%s %s skipped (%s)\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_VIDEO_COUNT" "video")" "$(format_bytes "$SCAN_VIDEO_BYTES")"
  [[ "$SCAN_AUDIO_COUNT" -gt 0 ]] && printf '  %s├─%s %s skipped (%s)\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_AUDIO_COUNT" "audio file")" "$(format_bytes "$SCAN_AUDIO_BYTES")"
  [[ "$SCAN_UNKNOWN_COUNT" -gt 0 ]] && printf '  %s├─%s %s unsupported or unknown (%s)\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_UNKNOWN_COUNT" "file")" "$(format_bytes "$SCAN_UNKNOWN_BYTES")"
  printf '  %s└─%s %s ignored\n' "${DIM}" "${RESET}" "$(plural_count "$SCAN_IGNORED_COUNT" "file")"
  note "Images, video, audio, unsupported files, and AGENTS.md control files are skipped."
}

render_copy_progress() {
  local processed="$1" total="$2" copied="$3" skipped="$4" current_file="${5:-}"
  local width=28 filled=0 bar="" i
  [[ "$total" -gt 0 ]] && filled=$((processed * width / total))
  for ((i = 0; i < width; i++)); do
    if (( i < filled )); then bar+="█"; else bar+="░"; fi
  done
  current_file="$(truncate_display_path "$current_file" 46)"
  printf '\r\033[2K  %s[%s]%s %d/%d %s (%d copied, %d skipped)' "${C}" "$bar" "${RESET}" "$processed" "$total" "$current_file" "$copied" "$skipped" >&2
}

copy_source() {
  local source_path="$1" dest_dir="$2"
  local total_files=$((SCAN_MARKDOWN_COUNT + SCAN_NATIVE_COUNT + SCAN_PDF_CONVERTIBLE_COUNT + SCAN_BINARY_COPYABLE_COUNT))
  [[ "$total_files" -gt 0 ]] || { warn "No copyable files found in source location."; return 1; }

  local copied=0 skipped=0 processed=0 converted=0 src_file rel_path raw_rel_path dest_file dest_parent
  local md_name md_dest pdf_converter_found
  pdf_converter_found="$(pdf_converter_available && echo 1 || echo 0)"
  render_copy_progress 0 "$total_files" 0 0 ""

  while IFS= read -r -d '' src_file; do
    should_skip_source_file "$src_file" && continue
    is_markdown_convertible_file "$src_file" || continue
    rel_path="${src_file#"$source_path"/}"
    raw_rel_path="$(markdown_raw_rel_path "$rel_path")"
    dest_file="$dest_dir/$raw_rel_path"
    dest_parent="$(dirname "$dest_file")"
    mkdir -p "$dest_parent"
    if [[ -f "$dest_file" ]]; then
      skipped=$((skipped + 1))
    else
      cp "$src_file" "$dest_file"
      copied=$((copied + 1))
    fi
    processed=$((processed + 1))
    render_copy_progress "$processed" "$total_files" "$copied" "$skipped" "$rel_path"
  done < <(find "$source_path" -type f -print0 2>/dev/null)

  while IFS= read -r -d '' src_file; do
    should_skip_source_file "$src_file" && continue
    is_native_readable_file "$src_file" || continue
    rel_path="${src_file#"$source_path"/}"
    dest_file="$dest_dir/$rel_path"
    dest_parent="$(dirname "$dest_file")"
    mkdir -p "$dest_parent"
    if [[ -f "$dest_file" ]]; then
      skipped=$((skipped + 1))
    else
      cp "$src_file" "$dest_file"
      copied=$((copied + 1))
    fi
    processed=$((processed + 1))
    render_copy_progress "$processed" "$total_files" "$copied" "$skipped" "$rel_path"
  done < <(find "$source_path" -type f -print0 2>/dev/null)

  # PDF conversion pass — convert PDFs to Markdown when pdf2md is available
  if [[ "$pdf_converter_found" -eq 1 && "$SCAN_PDF_CONVERTIBLE_COUNT" -gt 0 ]]; then
    local pdf_files
    pdf_files=()
    while IFS= read -r -d '' src_file; do
      should_skip_source_file "$src_file" && continue
      is_pdf_convertible_file "$src_file" || continue
      pdf_files+=("$src_file")
    done < <(find "$source_path" -type f -print0 2>/dev/null)

    if [[ ${#pdf_files[@]} -gt 0 ]]; then
      info "Converting ${#pdf_files[@]} PDFs to Markdown..."
      for src_file in "${pdf_files[@]}"; do
        rel_path="${src_file#"$source_path"/}"
        md_name="$(basename "${rel_path%.pdf}")"
        md_dest="$dest_dir/$(dirname "$rel_path")/${md_name}.md"
        dest_parent="$(dirname "$md_dest")"
        mkdir -p "$dest_parent"
        if [[ -f "$md_dest" ]]; then
          skipped=$((skipped + 1))
        else
          local pdf2md_cmd
          pdf2md_cmd="$(pdf2md_bin)"
          if [[ -n "$pdf2md_cmd" ]] && "$pdf2md_cmd" "$src_file" "$md_dest" 2>/dev/null; then
            converted=$((converted + 1))
            copied=$((copied + 1))
          else
            warn "Failed to convert: $(basename "$src_file") — copying as-is"
            cp "$src_file" "$dest_dir/$rel_path"
            copied=$((copied + 1))
          fi
        fi
        processed=$((processed + 1))
        render_copy_progress "$processed" "$total_files" "$copied" "$skipped" "$rel_path"
      done
    fi
  fi

  # Binary copyable pass (non-PDF, or when converter unavailable)
  while IFS= read -r -d '' src_file; do
    should_skip_source_file "$src_file" && continue
    # Skip PDFs already handled by the PDF conversion pass above
    [[ "$pdf_converter_found" -eq 1 ]] && is_pdf_convertible_file "$src_file" && continue
    is_binary_copyable_file "$src_file" || continue
    rel_path="${src_file#"$source_path"/}"
    dest_file="$dest_dir/$rel_path"
    dest_parent="$(dirname "$dest_file")"
    mkdir -p "$dest_parent"
    if [[ -f "$dest_file" ]]; then
      skipped=$((skipped + 1))
    else
      cp "$src_file" "$dest_file"
      copied=$((copied + 1))
    fi
    processed=$((processed + 1))
    render_copy_progress "$processed" "$total_files" "$copied" "$skipped" "$rel_path"
  done < <(find "$source_path" -type f -print0 2>/dev/null)

  printf '\n'
  ok "Raw records written to ${BOLD}${dest_dir}${RESET}"
}

choose_preferred_cli() {
  local options=("Claude Code" "Claude Code Desktop" "Codex" "Codex App" "OpenCode" "OpenCode Desktop" "Kilo" "Other")
  gum_choose "Preferred LLM CLI" "${options[@]}" 2>/dev/null || arrow_select "Preferred LLM CLI" "${options[@]}"
}

choose_handoff_action() {
  local options=("Copy launch command" "Run launch command now")
  gum_choose "Handoff action" "${options[@]}" 2>/dev/null || arrow_select "Handoff action" "${options[@]}"
}

confirm_action() {
  local prompt="$1" default="${2:-y}"
  if gum_available; then
    gum_confirm "$prompt" 2>/dev/null
    return $?
  fi
  confirm "$prompt" "$default"
}

print_path_list() {
  local title="$1"
  shift
  local count="$#" shown=0 path remaining
  [[ "$count" -gt 0 ]] || return 0

  info "${title}: ${count}"
  for path in "$@"; do
    shown=$((shown + 1))
    if [[ "$shown" -gt 8 ]]; then
      remaining=$((count - 8))
      note "... ${remaining} more"
      break
    fi
    note "$path"
  done
}

