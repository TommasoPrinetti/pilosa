        printf '%s' "$prompt" > "$_ptmp_oc"
        _ltmp_oc="$(mktemp /tmp/pilosa-launch.XXXXXX.command)"
        printf '#!/bin/bash\ncd %s && exec opencode --prompt "$(cat %s)" %s\n' \
          "$(printf '%q' "$root")" "$(printf '%q' "$_ptmp_oc")" "$(printf '%q' "$root")" > "$_ltmp_oc"
        chmod +x "$_ltmp_oc"
        open "$_ltmp_oc"
