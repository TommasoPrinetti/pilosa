#!/usr/bin/env bash
# pilosa → spinosa migration shim
# This binary was renamed to spinosa. This shim redirects users
# who type 'pilosa' out of habit to the new name.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPINOSA_BIN="${SCRIPT_DIR}/spinosa"

if [[ -x "$SPINOSA_BIN" ]]; then
  exec "$SPINOSA_BIN" "$@"
fi

echo ""
echo "  ┌──────────────────────────────────────────────────────────────┐"
echo "  │ pilosa has been renamed to spinosa                          │"
echo "  │                                                              │"
echo "  │ Run the new CLI directly:                                    │"
echo "  │   .bin/spinosa                                               │"
echo "  │                                                              │"
echo "  │ Or reinstall globally:                                       │"
echo "  │   curl -fsSL https://github.com/TommasoPrinetti/spinosa/     │"
echo "  │     releases/latest/install.sh | bash                        │"
echo "  └──────────────────────────────────────────────────────────────┘"
echo ""
exit 1
