engine_for_extension() {
  local ext="$1"
  ext_in_list "$ext" "$MARKDOWN_EXTENSIONS"       && { echo "renamer"; return; }
  ext_in_list "$ext" "$MARKITDOWN_EXTENSIONS"     && { echo "markitdown"; return; }
  ext_in_list "$ext" "$IMAGE_EXTENSIONS"          && { echo "rapidocr"; return; }
  [[ "$ext" == "pdf" ]]                           && { echo "pdf_classify"; return; }
  echo "none"
}



markdown_raw_rel_path() {
  local rel_path="$1" name dir stem ext
  name="$(basename "$rel_path")"
