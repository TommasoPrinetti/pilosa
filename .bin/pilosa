  fi
}

is_release_managed_role() {
  local role="$1"
  [[ "$role" != "user_state" && "$role" != "generated_state" ]]
}

next_sidecar_path() {
  local dst="$1"
  local sidecar="${dst}.pilosa-new"
  local n=1
  while [[ -e "$sidecar" ]]; do
    sidecar="${dst}.pilosa-new.${n}"
    n=$((n + 1))
  done
  echo "$sidecar"
}

resolve_latest_release_version() {
  local url
  if ! command -v curl >/dev/null 2>&1; then
    die "curl is required to resolve latest. Use --version X.Y.Z instead."
  fi
  spinner_start "Resolving latest version" >&2
  url="$(curl -fsSL -o /dev/null -w '%{url_effective}' "https://github.com/${PILOSA_REPO}/releases/latest" 2>/dev/null || true)"
  spinner_stop >&2
  [[ -n "$url" && "$url" != */latest ]] || die "Could not resolve latest version. Use --version X.Y.Z instead."
  basename "$url" | sed 's/^v//'
}

release_dir_version() {
  local release_dir="$1" version="$2"
  if [[ "$version" != "latest" ]]; then
    echo "$version"
    return
  fi
  basename "$release_dir" | sed 's/^v//'
}

prepare_release_framework() {
  local requested_version="$1" release_dir="$2" tmpdir="$3"
  local version archive_name archive_path checksums_path expected framework_dir

  if [[ -n "$release_dir" ]]; then
    version="$(release_dir_version "$release_dir" "$requested_version")"
  elif [[ "$requested_version" == "latest" ]]; then
    version="$(resolve_latest_release_version)"
  else
    version="$requested_version"
  fi

  archive_name="pilosa-framework-${version}.tar.gz"
  archive_path="${tmpdir}/${archive_name}"
  checksums_path="${tmpdir}/checksums.txt"

  if [[ -n "$release_dir" ]]; then
    [[ -f "${release_dir}/${archive_name}" ]] || die "Release archive not found: ${release_dir}/${archive_name}"
    [[ -f "${release_dir}/checksums.txt" ]] || die "Release checksums not found: ${release_dir}/checksums.txt"
    cp "${release_dir}/${archive_name}" "$archive_path"
    cp "${release_dir}/checksums.txt" "$checksums_path"
  else
    local base_url="${PILOSA_RELEASE_BASE_URL:-https://github.com/${PILOSA_REPO}/releases/download/v${version}}"
    printf '\n' >&2
    info "Downloading framework v${version}..."
    download_file "${base_url}/${archive_name}" "$archive_path"
    download_file "${base_url}/checksums.txt" "$checksums_path"
  fi

  expected="$(awk -v f="$archive_name" '$2 == f { print $1; exit }' "$checksums_path")"
  [[ -n "$expected" ]] || die "${archive_name} not found in checksums.txt"
  verify_checksum "$archive_path" "$expected"

  tar -xzf "$archive_path" -C "$tmpdir"
  framework_dir="${tmpdir}/pilosa-framework-${version}"
  [[ -f "${framework_dir}/.pilosa/framework-files.tsv" ]] || die "Release manifest missing from archive"
  printf '%s\t%s\n' "$version" "$framework_dir"
}

