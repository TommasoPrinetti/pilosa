#!/usr/bin/env bash
set -euo pipefail
ORIGINAL_ARGS=("$@")

# ── pilosa — CLI entry point ────────────────────────────────────────────────
# Usage: pilosa [new|onboard|update|check|sync|uninstall|help]
#
# Commands:
#   new       Create a new Pilosa workspace and run onboarding
#   onboard   Run onboarding on an existing workspace
#   update    Update workspace framework files from a release
#   check     Validate workspace integrity and configuration
#   sync      Sync agent and skill mirrors from canonical sources
#   uninstall Remove Pilosa from this system
#   help      Show this help

# ── ANSI colors (zero dependencies) ─────────────────────────────────────────
if [[ "${NO_COLOR:-}" == "1" ]] || [[ ! -t 1 ]]; then
  R="" G="" B="" Y="" C="" M="" DIM="" BOLD="" RESET=""
else
  R=$'\033[31m' G=$'\033[32m' B=$'\033[34m' Y=$'\033[33m'
  C=$'\033[36m' M=$'\033[35m' DIM=$'\033[2m' BOLD=$'\033[1m' RESET=$'\033[0m'
fi

# ── paths ───────────────────────────────────────────────────────────────────
PILOSA_HOME="${PILOSA_HOME:-$HOME/.pilosa}"
PILOSA_REPO="${PILOSA_REPO:-TommasoPrinetti/pilosa}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TODAY="$(date +%Y-%m-%d)"
USE_GUM="${USE_GUM:-0}"

# ── global cleanup trap ────────────────────────────────────────────────────
cleanup_on_exit() {
  # Kill spinner if running
  if [[ -n "${SPINNER_PID:-}" ]]; then
    kill "$SPINNER_PID" 2>/dev/null || true
    wait "$SPINNER_PID" 2>/dev/null || true
  fi
  # Reset terminal
  stty sane 2>/dev/null || true
}

trap cleanup_on_exit EXIT INT TERM

# Source file classes used by integrated onboarding.
MARKDOWN_EXTENSIONS="txt|rtf|textile|wiki|mediawiki|dokuwiki|pmwiki|outliner|workflowy|dynalist|yaml|yml|toml|css|js|ts|py|rb|sh|log|ini|cfg|conf|tex|bib|org|adoc|rst|tiddlywiki|logseq|roam|obsidian"
NATIVE_EXTENSIONS="md"
BINARY_COPYABLE_EXTENSIONS=""
# Engine: markitdown — convert Office docs, EPUB, HTML, ZIP, and text-based PDFs to .md
MARKITDOWN_EXTENSIONS="docx|pptx|xlsx|xls|epub|html|htm|msg|zip|json|csv|xml"
OPTION_SEP=$'\t'

# Resolve framework root:
#   - Dev mode: binary is in .bin/ of the repo → FRAMEWORK_ROOT is repo root
#   - Installed mode: binary is in ~/.pilosa/bin/ → framework is in ~/.pilosa/versions/<latest>/
resolve_framework_root() {
  # Dev mode: check if we're in the repo's .bin/
  local candidate="${SCRIPT_DIR}/.."
  if [[ -f "${candidate}/.pilosa/framework-files.tsv" ]]; then
    echo "$candidate"
    return
  fi

  # Installed mode: find latest version
  if [[ -d "${PILOSA_HOME}/versions" ]]; then
      local latest_version
      local portable_sort_args
      if sort -V /dev/null 2>/dev/null; then
        portable_sort_args=(sort -V)
      else
        portable_sort_args=(sort -t. -k1,1n -k2,2n -k3,3n)
      fi
      latest_version="$(ls -1 "${PILOSA_HOME}/versions" 2>/dev/null | "${portable_sort_args[@]}" | tail -1)"
    if [[ -n "$latest_version" ]]; then
      local fw_dir="${PILOSA_HOME}/versions/${latest_version}"
      # The archive unpacks to pilosa-framework-<version>/
      local fw_subdir
      fw_subdir="$(find "$fw_dir" -maxdepth 1 -type d -name 'pilosa-framework-*' 2>/dev/null | head -1)"
      if [[ -n "$fw_subdir" && -f "${fw_subdir}/.pilosa/framework-files.tsv" ]]; then
        echo "$fw_subdir"
        return
      fi
    fi
  fi

  echo ""
}

FRAMEWORK_ROOT="$(resolve_framework_root)"

# ── helpers ─────────────────────────────────────────────────────────────────
divider()   { printf '%s\n' "${DIM}$(printf '%.0s─' 1 {1..78})${RESET}"; }
header()    { printf '\n%s\n\n' "${BOLD}${C}$1${RESET}"; }
info()      { printf '  %s %s\n' "${DIM}→${RESET}" "$1"; }
ok()        { printf '  %s %s\n' "${G}✦${RESET}" "$1"; }
warn()      { printf '  %s %s\n' "${Y}⚠${RESET}" "$1" >&2; }
note()      { printf '  %s↳%s %s\n' "${DIM}" "${RESET}" "$1"; }
die()       { printf '\n  %s %s\n\n' "${R}✗${RESET}" "$1" >&2; exit 1; }
print_step(){ printf '\n  %s%s[%s/%s] %s%s\n' "${BOLD}" "${C}" "$1" "$2" "$3" "${RESET}"; }

read_from_tty() {
  if [[ -t 0 ]]; then
    IFS= read -r "$@"
  else
    # Try to read from /dev/tty if available, suppress all errors
    { [[ -r /dev/tty ]] && IFS= read -r "$@" < /dev/tty; } 2>/dev/null || return 1
  fi
}

spinner_start() {
  local msg="$1"
  SPINNER_PID=""
  [[ -t 1 ]] || return 0
  (
    local frames=("▁" "▃" "▄" "▅" "▆" "▇" "█" "▇" "▆" "▅" "▄" "▃")
    local i=0
    while true; do
      printf '\r\033[2K  %s%s%s %s' "${C}" "${frames[$((i % 12))]}" "${RESET}" "$msg" >&2
      i=$((i + 1))
      sleep 0.1
    done
  ) &
  SPINNER_PID=$!
}

spinner_stop() {
  [[ -n "${SPINNER_PID:-}" ]] || return 0
  kill "$SPINNER_PID" 2>/dev/null || true
  wait "$SPINNER_PID" 2>/dev/null || true
  SPINNER_PID=""
  printf '\r\033[2K' >&2
}

gum_available() {
  [[ "$USE_GUM" == "1" && -t 0 ]] || return 1
  local bin
  if [[ -x "${PILOSA_HOME}/bin/gum" ]]; then
    bin="${PILOSA_HOME}/bin/gum"
  else
    bin="$(command -v gum 2>/dev/null)" || return 1
  fi
  # Verify gum can actually open a TTY
  "$bin" --version >/dev/null 2>&1 || return 1
  return 0
}

gum_bin() {
  if [[ -x "${PILOSA_HOME}/bin/gum" ]]; then
    echo "${PILOSA_HOME}/bin/gum"
  else
    command -v gum 2>/dev/null
  fi
}

gum_input() {
  local prompt="$1" value="${2:-}" bin
  bin="$(gum_bin)" || return 127
  "$bin" input --placeholder "$prompt" --value "$value"
}

gum_file() {
  local title="$1" bin
  bin="$(gum_bin)" || return 127
  "$bin" file --directory --title "$title"
}

gum_choose() {
  local prompt="$1" bin
  shift
  bin="$(gum_bin)" || return 127
  "$bin" choose --header "$prompt" "$@"
}

gum_multi_choose() {
  local prompt="$1" selected_csv="$2" bin
  shift 2
  bin="$(gum_bin)" || return 127
  if [[ -n "$selected_csv" ]]; then
    "$bin" choose --header "$prompt" --no-limit --ordered --selected="$selected_csv" "$@"
  else
    "$bin" choose --header "$prompt" --no-limit --ordered "$@"
  fi
}

gum_confirm() {
  local prompt="$1" bin
  bin="$(gum_bin)" || return 127
  "$bin" confirm "$prompt"
}

prompt_input() {
  local prompt="$1" default="${2:-}" hint="${3:-}" value=""
  if gum_available; then
    value="$(gum_input "$prompt" "$default")" || value=""
    reset_terminal
  fi
  if [[ -z "$value" ]]; then
    value="$(ask "$prompt" "$default" "$hint")"
  fi
  echo "$value"
}

prompt_directory() {
  local prompt="$1" default="${2:-}" hint="${3:-}" value=""
  if gum_available; then
    value="$(gum_file "$prompt")" || value=""
    reset_terminal
  fi
  if [[ -z "$value" ]]; then
    value="$(ask "$prompt" "$default" "$hint")"
  fi
  echo "$value"
}

option_spec() {
  local value="$1" label="${2:-$1}" description="${3:-}"
  printf '%s%s%s%s%s' "$value" "$OPTION_SEP" "$label" "$OPTION_SEP" "$description"
}

option_value() {
  local spec="$1"
  if [[ "$spec" == *"$OPTION_SEP"* ]]; then
    printf '%s' "${spec%%"$OPTION_SEP"*}"
  else
    printf '%s' "$spec"
  fi
}

option_rest() {
  local spec="$1"
  if [[ "$spec" == *"$OPTION_SEP"* ]]; then
    printf '%s' "${spec#*"$OPTION_SEP"}"
  else
    printf ''
  fi
}

option_label() {
  local rest label
  rest="$(option_rest "$1")"
  if [[ "$rest" == *"$OPTION_SEP"* ]]; then
    label="${rest%%"$OPTION_SEP"*}"
    printf '%s' "${label:-$(option_value "$1")}"
  elif [[ -n "$rest" ]]; then
    printf '%s' "$rest"
  else
    printf '%s' "$(option_value "$1")"
  fi
}

option_description() {
  local rest
  rest="$(option_rest "$1")"
  if [[ "$rest" == *"$OPTION_SEP"* ]]; then
    printf '%s' "${rest#*"$OPTION_SEP"}"
  else
    printf ''
  fi
}

option_display() {
  local spec="$1" selected="${2:-0}" label desc
  label="$(option_label "$spec")"
  desc="$(option_description "$spec")"
  if [[ -n "$desc" ]]; then
    if [[ "$selected" == "1" ]]; then
      printf '%s%s%s %s- %s%s' "${BOLD}" "$label" "${RESET}" "${DIM}" "$desc" "${RESET}"
    else
      printf '%s %s- %s%s' "$label" "${DIM}" "$desc" "${RESET}"
    fi
  elif [[ "$selected" == "1" ]]; then
    printf '%s%s%s' "${BOLD}" "$label" "${RESET}"
  else
    printf '%s' "$label"
  fi
}

option_gum_display() {
  local spec="$1" label desc
  label="$(option_label "$spec")"
  desc="$(option_description "$spec")"
  if [[ -n "$desc" ]]; then
    printf '%s - %s' "$label" "$desc"
  else
    printf '%s' "$label"
  fi
}

prompt_choose() {
  local prompt="$1"
  shift
  local options=("$@")
  if gum_available; then
    local choice="" displays=() i
    for i in "${!options[@]}"; do
      displays+=("$(option_gum_display "${options[$i]}")")
    done
    if choice="$(gum_choose "$prompt" "${displays[@]}")"; then
      reset_terminal
      for i in "${!displays[@]}"; do
        if [[ "${displays[$i]}" == "$choice" ]]; then
          echo "$(option_value "${options[$i]}")"
          return 0
        fi
      done
      echo "$choice"
      return 0
    fi
    reset_terminal
  fi
  arrow_select "$prompt" "${options[@]}"
}

multi_values_contains() {
  local needle="$1"
  shift || true
  local item
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

prompt_multi_choose() {
  local prompt="$1"
  shift
  local options=("$@")
  MULTI_CHOOSE_RESULTS=()
  MULTI_CHOOSE_OPTIONS=("${options[@]}")
  MULTI_CHOOSE_SELECTED=()

  local option value
  for option in "${options[@]}"; do
    value="$(option_value "$option")"
    [[ "$value" == "__all__" ]] && continue
    MULTI_CHOOSE_SELECTED+=("$value")
  done

  if gum_available; then
    local displays=() preselected=() choice value
    for option in "${options[@]}"; do
      value="$(option_value "$option")"
      displays+=("$(option_gum_display "$option")")
      [[ "$value" == "__all__" ]] || preselected+=("$(option_gum_display "$option")")
    done
    local selected_csv=""
    if [[ ${#preselected[@]} -gt 0 ]]; then
      selected_csv="$(join_by "," "${preselected[@]}")"
    fi
    local gum_output=""
    if gum_output="$(gum_multi_choose "$prompt" "$selected_csv" "${displays[@]}")"; then
      reset_terminal
      MULTI_CHOOSE_SELECTED=()
      local line i
      while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        for i in "${!displays[@]}"; do
          if [[ "${displays[$i]}" == "$line" ]]; then
            value="$(option_value "${options[$i]}")"
            [[ "$value" == "__all__" ]] || MULTI_CHOOSE_SELECTED+=("$value")
            break
          fi
        done
      done <<< "$gum_output"
      MULTI_CHOOSE_RESULTS=()
      local selected_value
      for selected_value in "${MULTI_CHOOSE_SELECTED[@]-}"; do
        [[ -n "$selected_value" ]] && MULTI_CHOOSE_RESULTS+=("$selected_value")
      done
      return 0
    fi
    reset_terminal
    return 1
  fi

  multi_arrow_select "$prompt" "${options[@]}"
}

prompt_confirm() {
  local prompt="$1" default="${2:-y}"
  if gum_available; then
    local status=0
    if gum_confirm "$prompt"; then
      status=0
    else
      status=$?
    fi
    reset_terminal
    return "$status"
  fi
  confirm "$prompt" "$default"
}

join_by() {
  local sep="$1"
  shift
  local out="" item
  for item in "$@"; do
    if [[ -z "$out" ]]; then
      out="$item"
    else
      out="${out}${sep}${item}"
    fi
  done
  printf '%s' "$out"
}

ask() {
  local prompt="$1" default="${2:-}" hint="${3:-}"
  local fb=""
  [[ -n "$default" ]] && fb=" ${DIM}(${default})${RESET}"
  [[ -n "$hint" ]] && printf '  %s %s\n' "${DIM}↳${RESET}" "$hint" >&2
  printf '%s' "${BOLD}${prompt}${RESET}${fb}${DIM}: ${RESET}" >&2
  local reply
  if ! read_from_tty reply; then
    # If read_from_tty fails (no tty), try reading from stdin
    IFS= read -r reply || reply=""
  fi
  reply="${reply:-$default}"
  echo "$reply"
}

confirm() {
  local prompt="$1" default="${2:-y}"
  local hint="Y/n"
  [[ "$default" == "n" ]] && hint="y/N"
  local reply normalized
  trap 'printf "\n  Cancelled.\n" >&2; exit 1' INT
  while true; do
    printf '%s' "${BOLD}${prompt}${RESET} ${DIM}${hint}${RESET}: " >&2
    if ! read_from_tty reply; then
      # If read_from_tty fails (no tty), try reading from stdin
      if ! IFS= read -r reply; then
        # If stdin also fails (EOF), use default
        printf '\n  %s\n' "${R}Cannot read from terminal.${RESET}" >&2
        reply="$default"
      fi
    fi
    reply="${reply:-$default}"
    normalized="$(printf '%s' "$reply" | tr '[:upper:]' '[:lower:]')"
    case "$normalized" in
      y|yes) return 0 ;;
      n|no) return 1 ;;
      *) printf '  %s\n' "${R}Please answer y/yes or n/no.${RESET}" >&2 ;;
    esac
  done
}

reset_terminal() {
  stty sane 2>/dev/null || true
}

select_menu() {
  local prompt="$1"
  shift
  local options=("$@")

  printf '%s\n' "${BOLD}${prompt}${RESET}" >&2
  for i in "${!options[@]}"; do
    printf '  %s %s\n' "${DIM}$((i+1)).${RESET}" "$(option_display "${options[$i]}")" >&2
  done

  local choice
  while true; do
    printf '%s' "${DIM}  Enter number [1-${#options[@]}]: ${RESET}" >&2
    if ! read_from_tty choice; then
      # If read_from_tty fails (no tty), try reading from stdin
      if ! IFS= read -r choice; then
        # If stdin also fails (EOF), default to 1
        choice="1"
      fi
    fi
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#options[@]} )); then
      echo "$(option_value "${options[$((choice-1))]}")"
      return
    fi
    printf '  %s\n' "${R}Invalid choice. Try again.${RESET}" >&2
  done
}

arrow_select() {
  local prompt="$1"
  shift
  local options=("$@")

  if [[ "${NUMBERED:-0}" == "1" ]] || [[ ! -t 0 ]]; then
    select_menu "$prompt" "${options[@]}"
    return
  fi

  if ! command -v stty >/dev/null 2>&1; then
    select_menu "$prompt" "${options[@]}"
    return
  fi

  local count=${#options[@]}
  local current=0
  local key seq part
  local old_stty
  old_stty=$(stty -g 2>/dev/null) || { select_menu "$prompt" "${options[@]}"; return; }

  render_arrow_options() {
    local i
    for i in "${!options[@]}"; do
      if (( i == current )); then
        printf '\r\033[2K  %s %s %s\n' "${C}" "▶" "$(option_display "${options[$i]}" 1)" >&2
      else
        printf '\r\033[2K    %s\n' "$(option_display "${options[$i]}")" >&2
      fi
    done
  }

  clear_arrow_options() {
    local i
    printf '\033[%dF' "$count" >&2
    for i in "${!options[@]}"; do
      printf '\r\033[2K\n' >&2
    done
  }

  printf '\n  %s\n' "${BOLD}${prompt}${RESET}" >&2
  printf '  %s\n' "${DIM}↑/↓ to move, Enter to confirm, q to cancel${RESET}" >&2
  render_arrow_options

  if ! stty raw -echo 2>/dev/null; then
    clear_arrow_options
    printf '\n  %s arrow-key mode failed, falling back to numbered menu\n' "${Y}⚠${RESET}" >&2
    select_menu "$prompt" "${options[@]}"
    return
  fi

  local old_int_trap old_term_trap old_exit_trap
  old_int_trap="$(trap -p INT || true)"
  old_term_trap="$(trap -p TERM || true)"
  old_exit_trap="$(trap -p EXIT || true)"

  restore_arrow_traps() {
    if [[ -n "$old_int_trap" ]]; then eval "$old_int_trap"; else trap - INT; fi
    if [[ -n "$old_term_trap" ]]; then eval "$old_term_trap"; else trap - TERM; fi
    if [[ -n "$old_exit_trap" ]]; then eval "$old_exit_trap"; else trap - EXIT; fi
  }

  cleanup_arrow() {
    stty "$old_stty" 2>/dev/null || true
    printf '\033[?25h' >&2
    restore_arrow_traps
  }
  trap 'cleanup_arrow; printf "\n  Cancelled.\n" >&2; exit 1' INT TERM
  trap 'cleanup_arrow' EXIT

  while true; do
    IFS= read -r -n 1 -s key 2>/dev/null || { cleanup_arrow; return 1; }
    case "$key" in
      $'\x1b')
        seq=""
        while IFS= read -r -n 1 -s -t 1 part 2>/dev/null; do
          seq+="$part"
          [[ ${#seq} -ge 2 ]] && break
        done
        case "$seq" in
          '[A'|'OA') ((current--)); ((current < 0)) && current=$((count - 1)) ;;
          '[B'|'OB') ((current++)); ((current >= count)) && current=0 ;;
          *) continue ;;
        esac
        printf '\033[%dF' "$count" >&2
        render_arrow_options
        ;;
      ''|$'\r'|$'\n')
        cleanup_arrow
        echo "$(option_value "${options[$current]}")"
        return
        ;;
      q|Q)
        cleanup_arrow
        printf '\n  Cancelled.\n' >&2
        return 1
        ;;
    esac
  done
}

multi_option_is_selected() {
  local value="$1"
  if [[ "$value" == "__all__" ]]; then
    local option regular_value
    for option in "${MULTI_CHOOSE_OPTIONS[@]}"; do
      regular_value="$(option_value "$option")"
      [[ "$regular_value" == "__all__" ]] && continue
      multi_values_contains "$regular_value" "${MULTI_CHOOSE_SELECTED[@]-}" || return 1
    done
    return 0
  fi
  multi_values_contains "$value" "${MULTI_CHOOSE_SELECTED[@]-}"
}

toggle_multi_option() {
  local value="$1"
  local option regular_value updated=()
  if [[ "$value" == "__all__" ]]; then
    if multi_option_is_selected "__all__"; then
      MULTI_CHOOSE_SELECTED=()
    else
      MULTI_CHOOSE_SELECTED=()
      for option in "${MULTI_CHOOSE_OPTIONS[@]}"; do
        regular_value="$(option_value "$option")"
        [[ "$regular_value" == "__all__" ]] && continue
        MULTI_CHOOSE_SELECTED+=("$regular_value")
      done
    fi
    return
  fi

  if multi_values_contains "$value" "${MULTI_CHOOSE_SELECTED[@]-}"; then
    for regular_value in "${MULTI_CHOOSE_SELECTED[@]-}"; do
      [[ "$regular_value" == "$value" ]] || updated+=("$regular_value")
    done
    MULTI_CHOOSE_SELECTED=("${updated[@]}")
  else
    MULTI_CHOOSE_SELECTED+=("$value")
  fi
}

render_multi_option_line() {
  local option="$1" selected="${2:-0}" prefix="${3:-    }" current="${4:-0}"
  local marker="○"
  [[ "$selected" == "1" ]] && marker="●"
  printf '\r\033[2K%s%s %s\n' "$prefix" "$marker" "$(option_display "$option" "$current")" >&2
}

multi_select_menu() {
  local prompt="$1"
  shift
  local options=("$@")
  local choice continue_index=$(( ${#options[@]} + 1 )) cancel_index=$(( ${#options[@]} + 2 ))

  while true; do
    printf '%s\n' "${BOLD}${prompt}${RESET}" >&2
    printf '  %s\n' "${DIM}Toggle file types, then continue with the selected batches.${RESET}" >&2
    local i option value
    for i in "${!options[@]}"; do
      option="${options[$i]}"
      value="$(option_value "$option")"
      printf '  %s ' "${DIM}$((i+1)).${RESET}" >&2
      if multi_option_is_selected "$value"; then
        render_multi_option_line "$option" 1 "" 0
      else
        render_multi_option_line "$option" 0 "" 0
      fi
    done
    printf '  %s %s\n' "${DIM}${continue_index}.${RESET}" "Continue with selected file types" >&2
    printf '  %s %s\n' "${DIM}${cancel_index}.${RESET}" "Cancel selection" >&2
    printf '%s' "${DIM}  Enter number to toggle or continue: ${RESET}" >&2
    read_from_tty choice || choice="$continue_index"
    if [[ "$choice" =~ ^[0-9]+$ ]]; then
      if (( choice >= 1 && choice <= ${#options[@]} )); then
        toggle_multi_option "$(option_value "${options[$((choice-1))]}")"
        printf '\n' >&2
        continue
      fi
      if (( choice == continue_index )); then
        MULTI_CHOOSE_RESULTS=()
        local selected_value
        for selected_value in "${MULTI_CHOOSE_SELECTED[@]-}"; do
          [[ -n "$selected_value" ]] && MULTI_CHOOSE_RESULTS+=("$selected_value")
        done
        return 0
      fi
      if (( choice == cancel_index )); then
        return 1
      fi
    fi
    printf '  %s\n\n' "${R}Invalid choice. Try again.${RESET}" >&2
  done
}

multi_arrow_select() {
  local prompt="$1"
  shift
  local options=("$@")

  if [[ "${NUMBERED:-0}" == "1" ]] || [[ ! -t 0 ]]; then
    multi_select_menu "$prompt" "${options[@]}"
    return
  fi

  if ! command -v stty >/dev/null 2>&1; then
    multi_select_menu "$prompt" "${options[@]}"
    return
  fi

  local total_rows=$(( ${#options[@]} + 2 ))
  local current=${#options[@]} key seq part
  local old_stty
  old_stty=$(stty -g 2>/dev/null) || { multi_select_menu "$prompt" "${options[@]}"; return; }

  render_multi_arrow_rows() {
    local i option value
    for ((i = 0; i < total_rows; i++)); do
      if (( i < ${#options[@]} )); then
        option="${options[$i]}"
        value="$(option_value "$option")"
        local row="    "
        (( i == current )) && row="  ${C}▶${RESET} "
        if multi_option_is_selected "$value"; then
          render_multi_option_line "$option" 1 "$row" $(( i == current ? 1 : 0 ))
        else
          render_multi_option_line "$option" 0 "$row" $(( i == current ? 1 : 0 ))
        fi
      elif (( i == ${#options[@]} )); then
        if (( i == current )); then
          printf '\r\033[2K  %s▶%s %sContinue with selected file types%s\n' "${C}" "${RESET}" "${BOLD}" "${RESET}" >&2
        else
          printf '\r\033[2K    Continue with selected file types\n' >&2
        fi
      else
        if (( i == current )); then
          printf '\r\033[2K  %s▶%s %sCancel selection%s\n' "${C}" "${RESET}" "${BOLD}" "${RESET}" >&2
        else
          printf '\r\033[2K    Cancel selection\n' >&2
        fi
      fi
    done
  }

  clear_multi_arrow_rows() {
    local i
    printf '\033[%dF' "$total_rows" >&2
    for ((i = 0; i < total_rows; i++)); do
      printf '\r\033[2K\n' >&2
    done
  }

  printf '\n  %s\n' "${BOLD}${prompt}${RESET}" >&2
  printf '  %s\n' "${DIM}↑/↓ to move, Space to select, Enter to confirm, q to cancel${RESET}" >&2
  render_multi_arrow_rows

  if ! stty raw -echo 2>/dev/null; then
    clear_multi_arrow_rows
    printf '\n  %s arrow-key mode failed, falling back to numbered menu\n' "${Y}⚠${RESET}" >&2
    multi_select_menu "$prompt" "${options[@]}"
    return
  fi

  local old_int_trap old_term_trap old_exit_trap
  old_int_trap="$(trap -p INT || true)"
  old_term_trap="$(trap -p TERM || true)"
  old_exit_trap="$(trap -p EXIT || true)"

  restore_multi_arrow_traps() {
    if [[ -n "$old_int_trap" ]]; then eval "$old_int_trap"; else trap - INT; fi
    if [[ -n "$old_term_trap" ]]; then eval "$old_term_trap"; else trap - TERM; fi
    if [[ -n "$old_exit_trap" ]]; then eval "$old_exit_trap"; else trap - EXIT; fi
  }

  cleanup_multi_arrow() {
    stty "$old_stty" 2>/dev/null || true
    printf '\033[?25h' >&2
    restore_multi_arrow_traps
  }
  trap 'cleanup_multi_arrow; printf "\n  Cancelled.\n" >&2; exit 1' INT TERM
  trap 'cleanup_multi_arrow' EXIT

  while true; do
    IFS= read -r -n 1 -s key 2>/dev/null || { cleanup_multi_arrow; return 1; }
    case "$key" in
      $'\x1b')
        seq=""
        while IFS= read -r -n 1 -s -t 1 part 2>/dev/null; do
          seq+="$part"
          [[ ${#seq} -ge 2 ]] && break
        done
        case "$seq" in
          '[A'|'OA') ((current--)); ((current < 0)) && current=$((total_rows - 1)) ;;
          '[B'|'OB') ((current++)); ((current >= total_rows)) && current=0 ;;
          *) continue ;;
        esac
        printf '\033[%dF' "$total_rows" >&2
        render_multi_arrow_rows
        ;;
      ' '|''|$'\r'|$'\n')
        if (( current < ${#options[@]} )); then
          toggle_multi_option "$(option_value "${options[$current]}")"
          printf '\033[%dF' "$total_rows" >&2
          render_multi_arrow_rows
        elif (( current == ${#options[@]} )); then
          cleanup_multi_arrow
          MULTI_CHOOSE_RESULTS=()
          local selected_value
          for selected_value in "${MULTI_CHOOSE_SELECTED[@]-}"; do
            [[ -n "$selected_value" ]] && MULTI_CHOOSE_RESULTS+=("$selected_value")
          done
          return 0
        else
          cleanup_multi_arrow
          printf '\n  Cancelled.\n' >&2
          return 1
        fi
        ;;
      q|Q)
        cleanup_multi_arrow
        printf '\n  Cancelled.\n' >&2
        return 1
        ;;
    esac
  done
}

normalize_path_input() {
