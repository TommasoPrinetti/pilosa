run_integrated_onboarding() {
  local root="$1" project_title="$2" preselected_source="${3:-}"
  local source_path="" preferred_cli startup_prompt launch_command handoff_action

  print_step 1 3 "Source files folder"
  note "Specify the folder containing your research materials (documents, PDFs, notes)."
  note "These files will be COPIED into the workspace's raw/ directory."
  note "Nothing in the original folder is moved, renamed, or edited."

  # Use pre-selected source if provided (e.g. via --source-dir)
  if [[ -n "$preselected_source" ]]; then
    source_path="$(normalize_path_input "$preselected_source")"
    source_path="$(expand_home "$source_path")"
    info "Using pre-selected source: ${source_path}"
  elif gum_available; then
    if source_path="$(gum_file "Select source folder" 2>/dev/null)"; then
      source_path="$(normalize_path_input "$source_path")"
      # Validate Gum output — if it's not a real directory, discard it
      [[ -d "$source_path" ]] || source_path=""
    fi
  fi

  if [[ -z "$source_path" ]]; then
    while [[ -z "$source_path" ]]; do
      source_path="$(ask "Source folder (absolute path)" "" "e.g. /home/user/Documents/my-sources")"
      source_path="$(normalize_path_input "$source_path")"
      source_path="$(expand_home "$source_path")"
      [[ -z "$source_path" ]] && printf '  %s\n' "${R}Source folder is required.${RESET}" >&2
    done
  fi

  [[ -d "$source_path" ]] || die "Source folder does not exist: $source_path"
  ok "Source: ${BOLD}${source_path}${RESET}"

  print_step 2 3 "Corpus scan and consent"
  scan_source "$source_path"
  print_scan_summary

  if pdf_converter_available; then
    [[ "$SCAN_PDF_CONVERTIBLE_COUNT" -gt 0 ]] && ok "pdf2md found — $(plural_count "$SCAN_PDF_CONVERTIBLE_COUNT" "PDF") will be converted to Markdown"
  else
    [[ "$SCAN_BINARY_COPYABLE_COUNT" -gt 0 ]] && note "PDFs will be copied as-is. Re-run the installer to add pdf2md for PDF-to-Markdown conversion."
  fi

  local copyable_count=$((SCAN_MARKDOWN_COUNT + SCAN_NATIVE_COUNT + SCAN_PDF_CONVERTIBLE_COUNT + SCAN_BINARY_COPYABLE_COUNT))
  [[ "$copyable_count" -gt 0 ]] || die "No copyable files found in source location."
  if ! confirm_action "Write accepted raw copies into raw/?" "y"; then
    warn "No raw copies were written. Onboarding stopped after the scan."
    return 1
  fi
  copy_source "$source_path" "$root/raw"

  print_step 3 3 "Startup handoff"
  preferred_cli="$(choose_preferred_cli)" || return 1
  ok "CLI: ${BOLD}${preferred_cli}${RESET}"

  write_setup_files "$root" "$project_title" "$source_path" "$preferred_cli"
  sed -i.bak 's/setup_status: not_started/setup_status: cli_started/' "$root/.pilosa/workspace" 2>/dev/null || \
  sed -i '' 's/setup_status: not_started/setup_status: cli_started/' "$root/.pilosa/workspace" 2>/dev/null || true
  rm -f "$root/.pilosa/workspace.bak"

  startup_prompt="$(startup_prompt_text "$project_title" "$source_path" "$preferred_cli")"
  launch_command="$(build_launch_command "$root" "$preferred_cli" "$startup_prompt")"

  print_box "Pilosa Startup Prompt Preview" <<< "$(prompt_preview <<< "$startup_prompt")"
  print_box "Terminal Launch Command Preview" <<< "$(prompt_preview <<< "$launch_command")"

  handoff_action="$(choose_handoff_action)" || return 1
  if [[ "$handoff_action" == "Run launch command now" ]]; then
    run_cli_with_prompt "$root" "$preferred_cli" "$startup_prompt" || {
      warn "Could not run ${preferred_cli}. Copying the launch command instead."
      copy_to_clipboard "$launch_command" && ok "Launch command copied to your clipboard." || print_box "Terminal Launch Command — full text" <<< "$launch_command"
    }
  else
    copy_to_clipboard "$launch_command" && ok "Launch command copied to your clipboard." || print_box "Terminal Launch Command — full text" <<< "$launch_command"
  fi
}

# ── framework manifest reader ──────────────────────────────────────────────
# Reads framework-files.tsv and returns paths matching the given role filter.
# Usage: read_manifest [framework|user_state|mixed_framework_user]
read_manifest() {
  local filter="${1:-}"
  local tsv="${FRAMEWORK_ROOT}/.pilosa/framework-files.tsv"
  [[ -f "$tsv" ]] || die "Framework manifest not found: $tsv"

  while IFS=$'\t' read -r path role policy; do
    [[ "$path" == "path" ]] && continue  # skip header
    if [[ -z "$filter" || "$role" == "$filter" ]]; then
      echo "$path"
    fi
  done < "$tsv"
}

# ── detect installed LLM CLIs ──────────────────────────────────────────────
detect_llm_clis() {
  local clis
  clis=()
  command -v claude >/dev/null 2>&1 && clis+=("Claude Code")
  command -v codex >/dev/null 2>&1 && clis+=("Codex")
  command -v opencode >/dev/null 2>&1 && clis+=("OpenCode")
  command -v kilo >/dev/null 2>&1 && clis+=("Kilo")
  if [[ ${#clis[@]} -eq 0 ]]; then
    clis+=("Other (manual)")
  fi
  printf '%s\n' "${clis[@]}"
}

# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: uninstall
# ═══════════════════════════════════════════════════════════════════════════
cmd_uninstall() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-color) R="" G="" B="" Y="" C="" M="" DIM="" BOLD="" RESET=""; shift ;;
      --yes|-y) FORCE_YES="1"; shift ;;
      --help|-h) echo "Usage: pilosa uninstall [--yes]" >&2; return 0 ;;
      -*) die "Unknown option: $1" ;;
      *) shift ;;
    esac
  done

  local bin_dir="${PILOSA_BIN_DIR:-$HOME/.local/bin}"

  header "Pilosa — Uninstall"

  if [[ ! -d "$PILOSA_HOME" ]]; then
    info "Pilosa is not installed (${PILOSA_HOME} not found)."
    [[ -f "$bin_dir/pilosa" ]] && info "Found stray shim at ${bin_dir}/pilosa" || return 0
  fi

  echo ""
  info "This will remove:"
  [[ -d "$PILOSA_HOME" ]] && info "  ${PILOSA_HOME}/  (framework + binary)"
  [[ -f "$bin_dir/pilosa" ]] && info "  ${bin_dir}/pilosa  (shim)"
  echo ""
  warn "Research workspaces are NOT affected."
  echo ""

  if [[ "${FORCE_YES:-}" != "1" ]]; then
    if ! confirm "Remove Pilosa from this system?"; then
      info "Uninstall cancelled."
      return 0
    fi
  fi

  [[ -d "$PILOSA_HOME" ]] && rm -rf "$PILOSA_HOME" && ok "Removed ${PILOSA_HOME}"
  [[ -f "$bin_dir/pilosa" ]] && rm -f "$bin_dir/pilosa" && ok "Removed ${bin_dir}/pilosa"

  divider
  ok "Pilosa uninstalled."
  echo ""
  info "Any research workspaces you created are still intact."
  info "To remove a workspace, delete its directory."
  echo ""
}

# ═══════════════════════════════════════════════════════════════════════════
# COMMAND: help
# ═══════════════════════════════════════════════════════════════════════════
cmd_help() {
  header "Pilosa — Research Framework CLI"

  printf '  %s\n' "${BOLD}Usage:${RESET}"
  printf '    %s\n' "pilosa new [directory]    Create a new workspace and run onboarding"
  printf '    %s\n' "pilosa onboard [dir]     Run onboarding on an existing workspace"
  printf '    %s\n' "pilosa update [dir]      Update workspace framework files"
  printf '    %s\n' "pilosa upgrade           Upgrade Pilosa CLI to latest release"
  printf '    %s\n' "pilosa check [directory] Validate workspace integrity"
  printf '    %s\n' "pilosa sync              Sync agent and skill mirrors from canonical"
  printf '    %s\n' "pilosa uninstall         Remove Pilosa from this system"
  printf '    %s\n' "pilosa help              Show this help"
  printf '\n'

  # Detect workspace
  if [[ -f ".pilosa/workspace" ]]; then
    local fw_version project_name setup_status
    fw_version="$(grep 'framework_version:' .pilosa/workspace | awk '{print $2}')"
    project_name="$(grep 'project_name:' .pilosa/workspace | awk '{print $2}')"
    setup_status="$(grep 'setup_status:' .pilosa/workspace | awk '{print $2}')"
    divider
    printf '\n  %s %s\n' "${BOLD}Current workspace:${RESET}" "${project_name:-unknown}"
    printf '  %s %s\n' "${DIM}framework:${RESET}" "${fw_version:-unknown}"
    printf '  %s %s\n' "${DIM}status:${RESET}" "${setup_status:-unknown}"
