render_copy_progress() {
  local processed="$1" total="$2" copied="$3" skipped="$4" current_file="${5:-}"
  local width=28 filled=0 bar="" i
  [[ "$total" -gt 0 ]] && filled=$((processed * width / total))
  for ((i = 0; i < width; i++)); do
    if (( i < filled )); then bar+="█"; else bar+="░"; fi
  done
  current_file="$(truncate_display_path "$current_file" 46)"
  printf '\r\033[2K  %s%s%s %s[%s]%s %d/%d %s (%d copied, %d skipped)' "${C}" "$(spinner_frame "$processed")" "${RESET}" "${C}" "$bar" "${RESET}" "$processed" "$total" "$current_file" "$copied" "$skipped" >&2
}

render_pdf_progress() {
  local processed="$1" total="$2" converted="$3" skipped="$4" current_file="${5:-}"
  local width=28 filled=0 bar="" i
  [[ "$total" -gt 0 ]] && filled=$((processed * width / total))
  for ((i = 0; i < width; i++)); do
    if (( i < filled )); then bar+="◆"; else bar+="◇"; fi
  done
  current_file="$(truncate_display_path "$current_file" 44)"
  printf '\r\033[2K  %s%s PDF → text%s %s[%s]%s %d/%d %s (%d imported, %d skipped)' "${M}" "$(spinner_frame "$processed")" "${RESET}" "${M}" "$bar" "${RESET}" "$processed" "$total" "$current_file" "$converted" "$skipped" >&2
}

render_ocr_progress() {
  local processed="$1" total="$2" converted="$3" skipped="$4" current_file="${5:-}" page_info="${6:-}"
  local width=28 filled=0 bar="" i
  [[ "$total" -gt 0 ]] && filled=$((processed * width / total))
  for ((i = 0; i < width; i++)); do
    if (( i < filled )); then bar+="█"; else bar+="░"; fi
  done
  current_file="$(truncate_display_path "$current_file" 44)"
  local page_label=""
  [[ -n "$page_info" ]] && page_label=" (page ${page_info})"
  printf '\r\033[2K  %s%s%s %s[%s]%s %d/%d %s%s (%d converted, %d skipped)' "${M}" "$(spinner_frame "$processed")" "${RESET}" "${M}" "$bar" "${RESET}" "$processed" "$total" "$current_file" "$page_label" "$converted" "$skipped" >&2
}

copy_source() {
  local source_path="$1" dest_dir="$2"
  local total_files
  total_files="$(selected_copy_count)"
  [[ "$total_files" -gt 0 ]] || { warn "No copyable files found in source location."; return 1; }

  local copied=0 skipped=0 processed=0 converted=0 ocr_converted=0 ocr_skipped=0 src_file rel_path raw_rel_path dest_file dest_parent
  local md_name md_dest
  COPY_TOTAL_COUNT="$total_files"
  COPY_COPIED_COUNT=0
  COPY_SKIPPED_COUNT=0
  render_copy_progress 0 "$total_files" 0 0 ""

  while IFS= read -r -d '' src_file; do
    should_skip_source_file "$src_file" && continue
    is_markdown_convertible_file "$src_file" || continue
    import_extension_selected "$(file_ext "$src_file")" || continue
    rel_path="${src_file#"$source_path"/}"
    raw_rel_path="$(markdown_raw_rel_path "$rel_path")"
    dest_file="$dest_dir/$raw_rel_path"
    dest_parent="$(dirname "$dest_file")"
    mkdir -p "$dest_parent"
    if [[ -f "$dest_file" ]]; then
      skipped=$((skipped + 1))
    else
      cp "$src_file" "$dest_file"
      copied=$((copied + 1))
    fi
    processed=$((processed + 1))
    render_copy_progress "$processed" "$total_files" "$copied" "$skipped" "$rel_path"
  done < <(find "$source_path" -type f -print0 2>/dev/null)

  while IFS= read -r -d '' src_file; do
    should_skip_source_file "$src_file" && continue
    is_native_readable_file "$src_file" || continue
    import_extension_selected "$(file_ext "$src_file")" || continue
    rel_path="${src_file#"$source_path"/}"
    dest_file="$dest_dir/$rel_path"
    dest_parent="$(dirname "$dest_file")"
    mkdir -p "$dest_parent"
    if [[ -f "$dest_file" ]]; then
      skipped=$((skipped + 1))
    else
      cp "$src_file" "$dest_file"
      copied=$((copied + 1))
    fi
    processed=$((processed + 1))
    render_copy_progress "$processed" "$total_files" "$copied" "$skipped" "$rel_path"
  done < <(find "$source_path" -type f -print0 2>/dev/null)

  # RapidOCR OCR pass — PDFs and images → structured Markdown
  if [[ "${SCAN_OCR_CHOICE:-no}" == "yes" ]]; then
    if ! rapidocr_ocr_available; then
      warn "RapidOCR OCR not available — skipping OCR pass"
    else
      local ocr_files=()
      while IFS= read -r -d '' src_file; do
        should_skip_source_file "$src_file" && continue
        if is_rapidocr_pdf "$src_file" || is_rapidocr_image "$src_file"; then
          import_extension_selected "$(file_ext "$src_file")" || continue
          ocr_files+=("$src_file")
        fi
      done < <(find "$source_path" -type f -print0 2>/dev/null)

      if [[ ${#ocr_files[@]} -gt 0 ]]; then
        printf '\n'
        info "${M}OCR${RESET} Processing ${#ocr_files[@]} files with RapidOCR..."
        local ocr_total=${#ocr_files[@]} ocr_idx=0
        local _ocr_bin
        _ocr_bin="$(rapidocr_ocr_bin)" || _ocr_bin=""
        spinner_start "Loading OCR engine" >&2
        for src_file in "${ocr_files[@]}"; do
          rel_path="${src_file#"$source_path"/}"
          md_name="$(basename "$rel_path")"
          md_name="${md_name%.*}"
          md_dest="$dest_dir/$(dirname "$rel_path")/${md_name}.md"
          dest_parent="$(dirname "$md_dest")"
          mkdir -p "$dest_parent"
          if [[ -f "$md_dest" ]]; then
            skipped=$((skipped + 1))
            ocr_skipped=$((ocr_skipped + 1))
          else
            local _ocr_page="" _ocr_ok=1
            local _ocr_fifo
            _ocr_fifo="$(mktemp -u)"
            if [[ -n "$_ocr_bin" ]] && mkfifo "$_ocr_fifo" 2>/dev/null; then
              "$_ocr_bin" "$src_file" "$md_dest" 2>"$_ocr_fifo" &
              local _ocr_pid=$!
              while IFS= read -r _line < "$_ocr_fifo"; do
                [[ "$_line" == PROGRESS\ * ]] && _ocr_page="${_line#PROGRESS }"
              done
              wait "$_ocr_pid" 2>/dev/null
              _ocr_ok=$?
              rm -f "$_ocr_fifo"
            elif [[ -n "$_ocr_bin" ]]; then
              "$_ocr_bin" "$src_file" "$md_dest" 2>/dev/null
              _ocr_ok=$?
            else
              _ocr_ok=1
            fi
            if [[ "$_ocr_ok" -eq 0 ]]; then
              converted=$((converted + 1))
              ocr_converted=$((ocr_converted + 1))
              copied=$((copied + 1))
            else
              spinner_stop >&2
              printf '\n' >&2
              warn "OCR failed for $(basename "$src_file"), skipping"
              skipped=$((skipped + 1))
              ocr_skipped=$((ocr_skipped + 1))
            fi
          fi
          ocr_idx=$((ocr_idx + 1))
          if [[ "$ocr_idx" -eq 1 ]]; then
            spinner_stop >&2
          fi
          render_ocr_progress "$ocr_idx" "$ocr_total" "$ocr_converted" "$ocr_skipped" "$rel_path" "$_ocr_page"
          _ocr_page=""
        done
        printf '\n'
        ok "${M}OCR${RESET} Completed: ${ocr_converted} converted, ${ocr_skipped} skipped"
      fi
    fi
  fi

  # Binary copyable pass (non-OCR files)
  while IFS= read -r -d '' src_file; do
    should_skip_source_file "$src_file" && continue
    is_binary_copyable_file "$src_file" || continue
    import_extension_selected "$(file_ext "$src_file")" || continue
    rel_path="${src_file#"$source_path"/}"
    dest_file="$dest_dir/$rel_path"
    dest_parent="$(dirname "$dest_file")"
    mkdir -p "$dest_parent"
    if [[ -f "$dest_file" ]]; then
      skipped=$((skipped + 1))
    else
      cp "$src_file" "$dest_file"
      copied=$((copied + 1))
    fi
    processed=$((processed + 1))
    render_copy_progress "$processed" "$total_files" "$copied" "$skipped" "$rel_path"
  done < <(find "$source_path" -type f -print0 2>/dev/null)

  COPY_COPIED_COUNT="$copied"
  COPY_SKIPPED_COUNT="$skipped"
  COPY_OCR_CONVERTED_COUNT="${ocr_converted:-0}"
  COPY_OCR_SKIPPED_COUNT="${ocr_skipped:-0}"

  printf '\n'
  ok "Workspace source copy prepared in ${BOLD}$(dirname "$dest_dir")${RESET}"
}

