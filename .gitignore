# OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Agent-specific files (created by onboarding per user CLI preference)
# CLAUDE.md is auto-generated by sync-agents.sh from AGENTS.md (tracked in root)

# Archive temp
*.tmp
*.temp
*.swp
*.swo
*~

# Logs
*.log
raw/.ocr-processed.log

# IDE
.idea/
.vscode/
*.sublime-*
.cursorrules

# Obsidian — track snippets and appearance config, ignore everything else
.obsidian/*
!.obsidian/snippets/
!.obsidian/appearance.json

# Dependencies
node_modules/

# Secrets
.env*

# Python (for report generation scripts)
__pycache__/
*.pyc
*.pyo

# OS-generated metadata files
*.localized

# Trash directory: local-only archive of retired framework files.
# Keep on disk for history, never track in git.
# (except .gitkeep and AGENTS.md, which are framework files)
.trash/*
!.trash/.gitkeep
!.trash/AGENTS.md

# Auto-generated by sync-agents.sh (source of truth: .agents/agents/ and .agents/skills/)
.opencode/agents/
.opencode/skills/
.claude/agents/
.claude/skills/
.codex/skills/

# Per-workspace artifacts (generated by pilosa new / pilosa update)
# .pilosa/framework-files.tsv is tracked — it is the source manifest
.pilosa/manifest.tsv
.pilosa/workspace
.pilosa/update-report.md

# Release build output
dist/

# OpenCode package lock (generated by npm install)
.opencode/package-lock.json
.opencode/.gitignore
